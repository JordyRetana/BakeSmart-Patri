
@section Styles {
    <link rel="stylesheet" href="~/css/pages/inventory-index.css" asp-append-version="true" />
}
﻿@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inventario";
}

<div class="page-shell inventory-page">
    <div class="page-header inventory-header">
        <div>
            <h1 class="inventory-title">
                <i class="fas fa-boxes-stacked"></i>
                Gestión de inventario
            </h1>
            <p class="text-muted inventory-subtitle">
                Materias primas, productos terminados, empaques y movimientos conectados a pedidos y POS.
            </p>
        </div>

        <div class="page-actions inventory-actions">
            <input id="inventorySearch" class="form-control" placeholder="Buscar por código o descripción" />
            <select id="inventoryCategory" class="form-control inventory-category"></select>
            <button type="button" id="inventoryQuickActions" class="btn btn-primary">
                <i class="fas fa-bolt"></i>
                Nuevo producto
            </button>
            <button type="button" id="inventoryMovementActions" class="btn btn-outline">
                <i class="fas fa-right-left"></i>
                Movimiento
            </button>
        </div>
    </div>

    <div class="grid grid-4 inventory-kpi-grid">
        <div class="card inventory-kpi-card">
            <div class="text-muted">Productos</div>
            <h2 id="invTotal"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Activos</div>
            <h2 id="invActive"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Stock bajo</div>
            <h2 id="invLow"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Materias primas</div>
            <h2 id="invNegative"></h2>
        </div>
    </div>

    <div class="card inventory-presets-card">
        <div class="inventory-panel-header">
            <div>
                <h3 class="inventory-panel-title">Alta rápida de materia prima</h3>
                <p class="text-muted" style="margin:.35rem 0 0;">Plantillas comunes para registrar inventario real de repostería.</p>
            </div>
        </div>
        <div class="inventory-preset-grid">
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-HAR-', 'Harina pastelera', 'Secos', 'kg', 25, 15, 950)">
                <i class="fas fa-wheat-awn"></i><span>Harina</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-AZU-', 'Azúcar blanca', 'Secos', 'kg', 20, 10, 780)">
                <i class="fas fa-cubes-stacked"></i><span>Azúcar</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-MAN-', 'Mantequilla sin sal', 'Lácteos', 'kg', 8, 5, 4200)">
                <i class="fas fa-cheese"></i><span>Mantequilla</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('EMP-CAJ-', 'Caja para entregas', 'Cajas', 'unidad', 50, 20, 420, 'Empaque', 'Empaques')">
                <i class="fas fa-box"></i><span>Cajas</span><small>unidad</small>
            </button>
        </div>
    </div>

    <div class="card inventory-history-preview-card">
        <div class="inventory-panel-header">
            <div>
                <h3 class="inventory-panel-title">Últimos movimientos</h3>
            </div>
            <button type="button" class="btn btn-outline btn-sm" onclick="openInventoryQuickActions('history')">
                Ver historial completo
            </button>
        </div>

        <div class="table-container table-container--soft inventory-table-wrap inventory-table-wrap-preview">
            <table class="table inventory-table inventory-preview-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Producto</th>
                        <th>Movimiento</th>
                <th>Cantidad</th>
                        <th>Responsable</th>
                    </tr>
                </thead>
                <tbody id="movementPreviewTable"></tbody>
            </table>
        </div>
    </div>

    <template id="inventoryProductTemplate">
        <div class="inventory-modal-shell">
            <div class="inventory-modal-head">
                <h3 class="inventory-modal-title">Producto o materia prima</h3>
            </div>

            <form id="inventoryForm" class="inventory-modal-form">
                <input type="hidden" name="id" />

                <div>
                    <label>Código</label>
                    <input class="form-control" name="code" required />
                </div>

                <div>
                    <label>Precio</label>
                    <input class="form-control" name="price" type="number" min="0" step="0.01" required />
                </div>

                <div>
                    <label>Tipo</label>
                    <select class="form-control" name="type">
                        <option>Materia prima</option>
                        <option>Producto terminado</option>
                        <option>Empaque</option>
                        <option>Insumo operativo</option>
                    </select>
                </div>

                <div>
                    <label>Unidad</label>
                    <select class="form-control" name="unit">
                        <option>kg</option>
                        <option>g</option>
                        <option>L</option>
                        <option>ml</option>
                        <option>unidad</option>
                        <option>caja</option>
                        <option>paquete</option>
                    </select>
                </div>

                <div class="inventory-modal-full">
                    <label>Descripción</label>
                    <input class="form-control" name="description" required />
                </div>

                <div>
                    <label>Categoría</label>
                    <input class="form-control" name="category" required />
                </div>

                <div>
                    <label>Subcategoría</label>
                    <input class="form-control" name="subcategory" />
                </div>

                <div>
                    <label>Cantidad</label>
                    <input class="form-control" name="stock" type="number" min="0" step="0.01" required />
                </div>

                <div>
                    <label>Stock mínimo</label>
                    <input class="form-control" name="minStock" type="number" min="0" step="0.01" value="5" required />
                </div>

                <div class="inventory-modal-actions">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-save"></i>
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </template>

    <template id="inventoryMovementTemplate">
        <div class="inventory-modal-shell">
            <div class="inventory-modal-head">
                <h3 class="inventory-modal-title">Movimiento rápido</h3>
            </div>

            <form id="movementForm" class="inventory-modal-form">
                <div class="inventory-modal-full">
                    <label>Producto</label>
                    <select class="form-control" name="productId" id="movementProduct"></select>
                </div>

                <div>
                    <label>Tipo</label>
                    <select class="form-control" name="type">
                        <option value="ENTRADA">Entrada</option>
                        <option value="SALIDA">Salida</option>
                    </select>
                </div>

                <div>
                    <label>Cantidad</label>
                    <input class="form-control" name="quantity" type="number" min="0.01" step="0.01" placeholder="Cantidad" />
                </div>

                <div class="inventory-modal-full">
                    <label>Nota</label>
                    <input class="form-control" name="note" placeholder="Nota" />
                </div>

                <div class="inventory-modal-actions inventory-modal-full">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-check-circle"></i>
                        Registrar movimiento
                    </button>
                </div>
            </form>
        </div>
    </template>

    <template id="inventoryHistoryTemplate">
        <div class="inventory-modal-shell inventory-modal-shell-wide">
            <div class="inventory-modal-head">
                <h3 class="inventory-modal-title">Historial de inventario</h3>
            </div>

            <div class="compact-table-wrap inventory-history-modal-table">
                <table class="table inventory-table table--wide">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                        <th>Producto</th>
                        <th>Movimiento</th>
                        <th>Cantidad</th>
                        <th>Unidad</th>
                        <th>Responsable</th>
                        <th>Nota</th>
                        </tr>
                    </thead>
                    <tbody id="movementTable"></tbody>
                </table>
            </div>
        </div>
    </template>

    <div class="card inventory-products-card">
        <div class="inventory-panel-header">
            <div>
                <h3 class="inventory-panel-title">Productos</h3>
            </div>
        </div>

        <div class="table-container inventory-table-wrap">
            <table class="table inventory-table inventory-products-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Categoría</th>
                        <th>Costo / precio</th>
                        <th>Cantidad</th>
                        <th>Mínimo</th>
                        <th>Estado</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="inventoryTable"></tbody>
            </table>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        (() => {
            const search = document.getElementById('inventorySearch');
            const category = document.getElementById('inventoryCategory');
            const quickButton = document.getElementById('inventoryQuickActions');
            const movementButton = document.getElementById('inventoryMovementActions');
            let products = [];
            let movements = [];

            let categoriesInitialized = false;

            function normalizeProduct(p) {
                return {
                    id: p.id,
                    code: p.sku || p.code,
                    description: p.item || p.description,
                    type: p.type,
                    unit: p.unidad || p.unit,
                    category: p.category,
                    subcategory: p.subcategory,
                    price: Number(p.price || 0),
                    stock: Number(p.stock || 0),
                    minStock: Number(p.min || p.minStock || 0),
                    active: Boolean(p.active)
                };
            }

            async function loadInventory() {
                products = (await fetch('/api/inventory').then(r => r.json())).map(normalizeProduct);
                movements = await fetch('/api/inventory/movements').then(r => r.json());
            }

            function getCategories() {
                return ['Todas', ...new Set(products.map(p => p.category).filter(Boolean))];
            }

            function initializeCategories() {
                if (categoriesInitialized) return;

                const available = getCategories();
                category.innerHTML = available.map(c => `<option value="${c}">${c}</option>`).join('');
                category.value = 'Todas';
                category.dataset.selected = 'Todas';
                categoriesInitialized = true;
            }

            function refreshCategoriesIfNeeded() {
                const available = getCategories();
                const currentOptions = Array.from(category.options).map(o => o.value);

                if (available.join('|') !== currentOptions.join('|')) {
                    const selected = category.value || 'Todas';
                    category.innerHTML = available.map(c => `<option value="${c}">${c}</option>`).join('');
                    category.value = available.includes(selected) ? selected : 'Todas';
                    category.dataset.selected = category.value;
                }
            }

            function bindProductForm() {
                const form = document.getElementById('inventoryForm');
                if (!form) return;

                form.addEventListener('submit', (e) => {
                    e.preventDefault();
                    app.toast.info('Esta accion debe guardarse desde el formulario del sistema.');
                });
            }

            function bindMovementForm() {
                const movementForm = document.getElementById('movementForm');
                const movementProduct = document.getElementById('movementProduct');
                if (!movementForm || !movementProduct) return;

                movementProduct.innerHTML = products
                    .map(p => `<option value="${p.id}">${p.code} - ${p.description} (${p.stock} ${p.unit || 'unidad'})</option>`)
                    .join('');

                movementForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    app.toast.info('Esta accion debe registrarse desde el formulario del sistema.');
                });
            }

            function renderProducts() {
                const all = products;

                document.getElementById('invTotal').textContent = all.length;
                document.getElementById('invActive').textContent = all.filter(x => x.active).length;
                document.getElementById('invLow').textContent = all.filter(x => Number(x.stock) <= Number(x.minStock ?? 5)).length;
                document.getElementById('invNegative').textContent = all.filter(x => x.type === 'Materia prima').length;

                refreshCategoriesIfNeeded();

                const q = search.value.trim().toLowerCase();
                const c = category.value || 'Todas';

                const rows = all.filter(p =>
                    (!q || p.code.toLowerCase().includes(q) || p.description.toLowerCase().includes(q)) &&
                    (c === 'Todas' || p.category === c)
                );

                document.getElementById('inventoryTable').innerHTML = rows.map(p => `
                    <tr>
                        <td><strong>${p.code}</strong></td>
                        <td>
                            ${p.description}
                            <div class="text-muted" style="font-size:.8rem;">${p.subcategory || 'Sin subcategoría'} · ${p.unit || 'unidad'}</div>
                        </td>
                        <td><span class="inventory-type-chip">${p.type || 'Producto terminado'}</span></td>
                        <td>${p.category}</td>
                        <td>${app.utils.formatCurrency(p.price)}</td>
                        <td>
                            <span class="badge ${Number(p.stock) <= Number(p.minStock ?? 5) ? 'badge-warning' : 'badge-success'}">${p.stock} ${p.unit || ''}</span>
                        </td>
                        <td>${p.minStock ?? 5} ${p.unit || ''}</td>
                        <td>
                            <span class="badge ${p.active ? 'badge-success' : 'badge-warning'}">
                                ${p.active ? 'Activo' : 'Inactivo'}
                            </span>
                        </td>
                        <td class="text-right">
                            <button class="btn btn-outline btn-sm" onclick="editProduct(${p.id})">Editar</button>
                            <button class="btn btn-outline btn-sm" onclick="toggleProduct(${p.id})">
                                ${p.active ? 'Desactivar' : 'Activar'}
                            </button>
                        </td>
                    </tr>
                `).join('') || `
                    <tr>
                        <td colspan="9" class="text-center text-muted">No hay productos para mostrar.</td>
                    </tr>
                `;
            }

            function renderMovements() {
                const rows = movements;
                const preview = rows.slice(0, 6);

                document.getElementById('movementPreviewTable').innerHTML = preview.map(m => `
                    <tr>
                        <td>${new Date(m.createdAt).toLocaleString('es-CR')}</td>
                        <td>${m.code}</td>
                        <td><span class="badge badge-info">${m.type}</span></td>
                        <td>${m.quantity} ${m.unit || ''}</td>
                        <td>${m.responsible}</td>
                    </tr>
                `).join('') || `
                    <tr>
                        <td colspan="5" class="text-center text-muted">No hay movimientos registrados.</td>
                    </tr>
                `;

                const historyTable = document.getElementById('movementTable');
                if (historyTable) {
                    historyTable.innerHTML = rows.map(m => `
                        <tr>
                            <td>${new Date(m.createdAt).toLocaleString('es-CR')}</td>
                            <td>${m.code}</td>
                            <td><span class="badge badge-info">${m.type}</span></td>
                            <td>${m.quantity}</td>
                            <td>${m.unit || '-'}</td>
                            <td>${m.responsible}</td>
                            <td>${m.note || '-'}</td>
                        </tr>
                    `).join('') || `
                        <tr>
                            <td colspan="7" class="text-center text-muted">No hay movimientos registrados.</td>
                        </tr>
                    `;
                }
            }

            async function refreshAll() {
                await loadInventory();
                renderProducts();
                renderMovements();
            }

            window.openInventoryQuickActions = (section = 'product') => {
                const templates = {
                    product: { title: 'Producto o materia prima', selector: '#inventoryProductTemplate', maxWidth: '980px' },
                    movement: { title: 'Movimiento', selector: '#inventoryMovementTemplate', maxWidth: '980px' },
                    history: { title: 'Historial de inventario', selector: '#inventoryHistoryTemplate', maxWidth: '1280px' }
                };

                const selected = templates[section] || templates.product;
                const template = document.querySelector(selected.selector);

                app.modal.open({
                    title: selected.title,
                    maxWidth: selected.maxWidth,
                    content: template ? template.innerHTML : ''
                });

                if (section === 'product') bindProductForm();
                if (section === 'movement') bindMovementForm();
                if (section === 'history') renderMovements();
            };

            window.editProduct = (id) => {
                openInventoryQuickActions('product');

                const item = products.find(x => x.id === id);
                const form = document.getElementById('inventoryForm');
                if (!item || !form) return;

                for (const [key, value] of Object.entries(item)) {
                    const input = form.querySelector(`[name="${key}"]`);
                    if (input) input.value = value;
                }
            };

            window.openIngredientPreset = (codePrefix, description, subcategory, unit, stock, minStock, price, type = 'Materia prima', categoryName = 'Ingredientes') => {
                openInventoryQuickActions('product');

                const form = document.getElementById('inventoryForm');
                if (!form) return;

                const next = String(Date.now()).slice(-3);
                form.code.value = `${codePrefix}${next}`.toUpperCase();
                form.description.value = description;
                form.type.value = type;
                form.unit.value = unit;
                form.category.value = categoryName;
                form.subcategory.value = subcategory;
                form.price.value = price;
                form.stock.value = stock;
                form.minStock.value = minStock;
            };

            window.toggleProduct = (id) => {
                app.toast.info('Esta accion debe actualizarse desde el sistema.');
            };

            quickButton.addEventListener('click', () => openInventoryQuickActions('product'));
            movementButton.addEventListener('click', () => openInventoryQuickActions('movement'));

            search.addEventListener('input', renderProducts);

            category.addEventListener('change', () => {
                category.dataset.selected = category.value;
                renderProducts();
            });

            refreshAll().then(initializeCategories).catch(error => app.toast.error(error.message));
        })();
    </script>
}
