@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard-index.css" asp-append-version="true" />
}

<div class="page-shell dashboard-page">
    <div class="page-header dashboard-header">
        <div>
            <h1 class="dashboard-title"><i class="fas fa-chart-line"></i> Dashboard operativo</h1>
            <p class="text-muted dashboard-subtitle">Centro de control para pedidos, produccion, inventario y reportes.</p>
        </div>
        <div class="dashboard-actions">
            <a class="btn btn-primary" href="/Pos"><i class="fas fa-cash-register"></i> Abrir POS</a>
            <a class="btn btn-outline" href="/Reports"><i class="fas fa-file-lines"></i> Reportes</a>
        </div>
    </div>

    <div class="grid grid-4 dashboard-kpis">
        <div class="card dashboard-kpi"><span class="text-muted">Pedidos hoy</span><h2 id="dbOrders">0</h2><small id="dbOrdersHint"></small></div>
        <div class="card dashboard-kpi"><span class="text-muted">Ventas</span><h2 id="dbSales">0</h2><small id="dbSalesHint"></small></div>
        <div class="card dashboard-kpi"><span class="text-muted">Produccion activa</span><h2 id="dbProduction">0</h2><small id="dbProductionHint"></small></div>
        <div class="card dashboard-kpi"><span class="text-muted">Stock bajo</span><h2 id="dbLowStock">0</h2><small id="dbLowStockHint"></small></div>
    </div>

    <div class="dashboard-main-grid">
        <section class="card dashboard-orders-card">
            <div class="dashboard-section-head">
                <div>
                    <h3>Pedidos recientes</h3>
                    <p class="text-muted">Resumen reciente de actividad.</p>
                </div>
                <a class="btn btn-outline btn-sm" href="/Orders">Ver pedidos</a>
            </div>
            <div class="table-container">
                <table class="table table--wide">
                    <thead><tr><th>Pedido</th><th>Cliente</th><th>Estado</th><th>Pago</th><th>Total</th></tr></thead>
                    <tbody id="dbOrdersTable"></tbody>
                </table>
            </div>
        </section>

        <aside class="dashboard-side-stack">
            <section class="card">
                <div class="dashboard-section-head"><h3>Acciones rapidas</h3></div>
                <div class="dashboard-shortcuts">
                    <a href="/Production"><i class="fas fa-utensils"></i><span>Produccion</span></a>
                    <a href="/Inventory"><i class="fas fa-boxes-stacked"></i><span>Inventario</span></a>
                    <a href="/Marketing"><i class="fas fa-bullhorn"></i><span>Marketing</span></a>
                    <a href="/Accounting"><i class="fas fa-calculator"></i><span>Contabilidad</span></a>
                </div>
            </section>

            <section class="card">
                <div class="dashboard-section-head"><h3>Alertas</h3></div>
                <div id="dbAlerts" class="dashboard-alerts"></div>
            </section>
        </aside>
    </div>

    <div class="dashboard-bottom-grid">
        <section class="card">
            <div class="dashboard-section-head">
                <h3>Cola de produccion</h3>
                <a class="btn btn-outline btn-sm" href="/Production">Gestionar</a>
            </div>
            <div id="dbProductionQueue" class="dashboard-list"></div>
        </section>

        <section class="card">
            <div class="dashboard-section-head"><h3>Actividad reciente</h3></div>
            <div id="dbActivity" class="dashboard-list"></div>
        </section>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const format = value => app.utils.formatCurrency(Number(value || 0));
    const statusOf = order => order.estado || order.status || '';

    async function renderDashboard() {
        await BakeSmartStore.refresh();

        const dashboard = await fetch('/api/dashboard').then(r => r.json());
        const orders = BakeSmartStore.orders.list();
        const inventory = BakeSmartStore.reports.inventory();
        const logs = BakeSmartStore.logs();
        const kpis = dashboard.kpis || [];
        const getKpi = (label, fallback) => kpis.find(x => x.label === label)?.value ?? fallback;

        const pendingPayments = orders.filter(o => (o.paymentStatus || '') !== 'Pagado');
        const production = orders.filter(o => ['Confirmado', 'En produccion', 'En producción', 'Listo', 'En camino'].includes(statusOf(o)));
        const lowStock = getKpi('Alertas inventario', inventory.lowStock);

        document.getElementById('dbOrders').textContent = getKpi('Pedidos hoy', orders.length);
        document.getElementById('dbOrdersHint').textContent = `${pendingPayments.length} con pago pendiente`;
        document.getElementById('dbSales').textContent = format(getKpi('Ventas (CRC)', 0));
        document.getElementById('dbSalesHint').textContent = 'ventas registradas';
        document.getElementById('dbProduction').textContent = production.length;
        document.getElementById('dbProductionHint').textContent = `${orders.filter(o => statusOf(o) === 'Confirmado').length} listos para iniciar`;
        document.getElementById('dbLowStock').textContent = lowStock;
        document.getElementById('dbLowStockHint').textContent = lowStock ? 'requiere revision' : 'inventario estable';

        document.getElementById('dbOrdersTable').innerHTML = orders.slice(0, 7).map(o => `
            <tr>
                <td><strong>#${o.id}</strong></td>
                <td>${o.cliente || o.customerName || '-'}</td>
                <td><span class="badge badge-primary">${statusOf(o)}</span></td>
                <td><span class="badge ${(o.paymentStatus || '') === 'Pagado' ? 'badge-success' : 'badge-warning'}">${o.paymentStatus || '-'}</span></td>
                <td>${format(o.total)}</td>
            </tr>
        `).join('') || `<tr><td colspan="5" class="text-center text-muted">No hay pedidos.</td></tr>`;

        const alerts = [];
        if (Number(lowStock) > 0) alerts.push({ icon: 'fa-box-open', text: `${lowStock} productos tienen stock bajo.` });
        if (pendingPayments.length) alerts.push({ icon: 'fa-money-bill-wave', text: `${pendingPayments.length} pedidos necesitan pago.` });
        if (!alerts.length) alerts.push({ icon: 'fa-circle-check', text: 'No hay alertas criticas en este momento.' });
        document.getElementById('dbAlerts').innerHTML = alerts.map(a => `<div class="dashboard-alert"><i class="fas ${a.icon}"></i>${a.text}</div>`).join('');

        document.getElementById('dbProductionQueue').innerHTML = orders
            .filter(o => statusOf(o) !== 'Entregado')
            .slice(0, 5)
            .map(o => `<div class="dashboard-list-item"><div><strong>#${o.id} - ${o.cliente || o.customerName}</strong><span class="text-muted">${o.producto || 'Pedido personalizado'}</span></div><span class="badge badge-info">${statusOf(o)}</span></div>`)
            .join('') || `<div class="text-muted">No hay cola activa.</div>`;

        document.getElementById('dbActivity').innerHTML = logs.slice(0, 6).map(log => `
            <div class="dashboard-list-item">
                <div><strong>${String(log.type || '').replaceAll('_', ' ')}</strong><span class="text-muted">${log.detail || ''}</span></div>
                <span class="text-muted">${new Date(log.createdAt).toLocaleDateString('es-CR')}</span>
            </div>
        `).join('') || `<div class="text-muted">No hay actividad registrada.</div>`;
    }

    renderDashboard().catch(error => app.toast.error(error.message));
})();
</script>
}
