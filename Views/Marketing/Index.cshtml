@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Marketing";
}

<div class="page-shell marketing-page">
    <div class="page-header marketing-header">
        <div>
            <h1 class="marketing-title">
                <i class="fas fa-bullhorn"></i>
                Marketing y clientes frecuentes
            </h1>
            <p class="text-muted marketing-subtitle">
                Búsqueda de clientes, registro como frecuentes y manejo de promociones.
            </p>
        </div>

        <div class="marketing-search-box">
            <input id="marketingSearch" class="form-control" placeholder="Buscar clientes" />
        </div>
    </div>

    <div class="grid grid-3 marketing-kpi-grid">
        <div class="card marketing-kpi-card">
            <div class="text-muted">Clientes frecuentes</div>
            <h2 id="mkFrequentCount"></h2>
        </div>

        <div class="card marketing-kpi-card">
            <div class="text-muted">Promociones activas</div>
            <h2 id="mkPromoCount"></h2>
        </div>

        <div class="card marketing-kpi-card">
            <div class="text-muted">Descuento cliente frecuente</div>
            <h2 id="mkDiscount"></h2>
        </div>
    </div>

    <div class="marketing-main-grid">
        <div class="card marketing-customers-card">
            <div class="marketing-panel-header">
                <div>
                    <h3 class="marketing-panel-title">Clientes</h3>
                </div>
            </div>

            <div class="table-container marketing-table-wrap">
                <table class="table marketing-table marketing-customers-table">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Contacto</th>
                            <th>Total gastado</th>
                            <th>Frecuente</th>
                            <th class="text-right">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="marketingCustomers"></tbody>
                </table>
            </div>
        </div>

        <div class="card marketing-promotions-card">
            <div class="marketing-panel-header">
                <div>
                    <h3 class="marketing-panel-title">Nueva promoción</h3>
                </div>
            </div>

            <form id="promotionForm" class="marketing-form">
                <div class="marketing-form-block marketing-form-full">
                    <label>Nombre de la promoción</label>
                    <input class="form-control" name="name" placeholder="Nombre de la promoción" required />
                </div>

                <div class="marketing-form-grid">
                    <div class="marketing-form-block">
                        <label>Fecha de inicio</label>
                        <input class="form-control" type="date" name="startDate" required />
                    </div>

                    <div class="marketing-form-block">
                        <label>Fecha de fin</label>
                        <input class="form-control" type="date" name="endDate" required />
                    </div>
                </div>

                <div class="marketing-form-block marketing-form-full">
                    <label>Descuento</label>
                    <input class="form-control" type="number" min="0.01" step="0.01" max="1" name="discount" placeholder="Ej. 0.10" required />
                </div>

                <button class="btn btn-primary marketing-submit-btn" type="submit">
                    Guardar promoción
                </button>
            </form>

            <div class="hr"></div>

            <div class="marketing-panel-header marketing-panel-header-compact">
                <div>
                    <h3 class="marketing-panel-title">Promociones registradas</h3>
                </div>
            </div>

            <div id="promotionsList" class="marketing-promotions-list"></div>
        </div>
    </div>
</div>

<style>
    .marketing-page {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

        .marketing-page,
        .marketing-page * {
            min-width: 0;
        }

    .marketing-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .marketing-title {
        margin: 0;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

        .marketing-title i {
            color: var(--primary);
        }

    .marketing-subtitle {
        margin: .35rem 0 0;
    }

    .marketing-search-box {
        width: 100%;
        max-width: 320px;
    }

    .marketing-kpi-grid {
        gap: 1rem;
    }

    .marketing-kpi-card h2 {
        margin: .35rem 0 0;
    }

    .marketing-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(360px, .8fr);
        gap: 1rem;
        align-items: start;
    }

    .marketing-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .marketing-panel-header-compact {
        margin-bottom: .85rem;
    }

    .marketing-panel-title {
        margin: 0;
        font-size: 1.15rem;
    }

    .marketing-table-wrap {
        max-width: 100%;
        overflow: auto;
    }

    .marketing-table {
        width: 100%;
        min-width: 0 !important;
        margin: 0;
    }

    .marketing-customers-table {
        table-layout: fixed;
    }

        .marketing-customers-table th:nth-child(1),
        .marketing-customers-table td:nth-child(1) {
            width: 29%;
        }

        .marketing-customers-table th:nth-child(2),
        .marketing-customers-table td:nth-child(2) {
            width: 27%;
        }

        .marketing-customers-table th:nth-child(3),
        .marketing-customers-table td:nth-child(3) {
            width: 16%;
            white-space: nowrap;
        }

        .marketing-customers-table th:nth-child(4),
        .marketing-customers-table td:nth-child(4) {
            width: 12%;
            white-space: nowrap;
        }

        .marketing-customers-table th:nth-child(5),
        .marketing-customers-table td:nth-child(5) {
            width: 16%;
            white-space: nowrap;
            text-align: right;
        }

        .marketing-customers-table td:nth-child(1),
        .marketing-customers-table td:nth-child(2) {
            white-space: normal;
            word-break: break-word;
        }

        .marketing-customers-table .btn-sm {
            min-width: 132px;
        }

    .marketing-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--bg-card);
    }

    .marketing-form {
        display: grid;
        gap: .9rem;
    }

    .marketing-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .marketing-form-block {
        display: grid;
        gap: .35rem;
    }

        .marketing-form-block label {
            margin: 0;
            font-size: .82rem;
            font-weight: 700;
            color: var(--text);
        }

    .marketing-form-full {
        width: 100%;
    }

    .marketing-submit-btn {
        width: 100%;
    }

    .marketing-promotions-list {
        display: grid;
        gap: .75rem;
    }

    .marketing-promo-card {
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: .9rem 1rem;
        background: var(--bg-card);
    }

    .marketing-promo-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
    }

    .marketing-promo-name {
        font-weight: 700;
        margin-bottom: .2rem;
    }

    .marketing-promo-dates {
        color: var(--text-light);
        font-size: .9rem;
    }

    .marketing-customers-card,
    .marketing-promotions-card {
        align-self: start;
    }

    .marketing-page .card:hover {
        transform: none;
        box-shadow: var(--shadow-sm);
        border-color: var(--border);
    }

        .marketing-page .card:hover::after {
            opacity: 0;
        }

    .marketing-page .table tbody tr:hover {
        transform: none;
        box-shadow: none;
        background: var(--bg-alt);
    }

    .marketing-page .btn:hover,
    .marketing-page .btn-primary:hover,
    .marketing-page .btn-outline:hover,
    .marketing-page .btn-secondary:hover,
    .marketing-page .btn-ghost:hover {
        transform: none;
    }

    .marketing-page .form-control:focus,
    .marketing-page input:focus,
    .marketing-page select:focus,
    .marketing-page textarea:focus {
        transform: none;
    }

    @@media (max-width: 1200px) {
        .marketing-main-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .marketing-search-box {
            max-width: 100%;
        }

        .marketing-form-grid {
            grid-template-columns: 1fr;
        }

        .marketing-customers-table {
            table-layout: auto;
            min-width: 920px !important;
        }
    }
</style>

@section Scripts {
    <script>
        (() => {
            const search = document.getElementById('marketingSearch');
            let pageInitialized = false;

            function render() {
                const customers = BakeSmartStore.customers.search(search.value);
                const promotions = BakeSmartStore.marketing.promotions();

                document.getElementById('mkFrequentCount').textContent = customers.filter(x => x.frequent).length;
                document.getElementById('mkPromoCount').textContent = promotions.filter(x => x.active).length;
                document.getElementById('mkDiscount').textContent =
                    `${(BakeSmartStore.pos.config().frequentCustomerDiscount * 100).toFixed(0)}%`;

                document.getElementById('marketingCustomers').innerHTML = customers.map(c => `
                    <tr>
                        <td>
                            <strong>${c.fullName}</strong>
                            <div class="text-muted" style="font-size:.8rem;">${c.address || '-'}</div>
                        </td>
                        <td>
                            ${c.email || '-'}
                            <div class="text-muted" style="font-size:.8rem;">${c.phone || '-'}</div>
                        </td>
                        <td>${app.utils.formatCurrency(c.totalSpent || 0)}</td>
                        <td>
                            <span class="badge ${c.frequent ? 'badge-success' : 'badge-warning'}">
                                ${c.frequent ? 'Sí' : 'No'}
                            </span>
                        </td>
                        <td class="text-right">
                            ${!c.frequent
                                ? `<button class="btn btn-outline btn-sm" onclick="makeFrequent(${c.id})">Marcar frecuente</button>`
                                : ''}
                        </td>
                    </tr>
                `).join('') || `
                    <tr>
                        <td colspan="5" class="text-center text-muted">No se encontraron clientes.</td>
                    </tr>
                `;

                document.getElementById('promotionsList').innerHTML = promotions.map(p => `
                    <div class="marketing-promo-card">
                        <div class="marketing-promo-row">
                            <div>
                                <div class="marketing-promo-name">${p.name}</div>
                                <div class="marketing-promo-dates">${p.startDate} al ${p.endDate}</div>
                            </div>
                            <span class="badge badge-primary">${(p.discount * 100).toFixed(0)}%</span>
                        </div>
                    </div>
                `).join('') || `
                    <div class="text-muted">No hay promociones registradas.</div>
                `;
            }

            window.makeFrequent = (id) => {
                try {
                    BakeSmartStore.customers.addFrequent(id);
                    app.toast.success('Cliente agregado a frecuentes.');
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            document.getElementById('promotionForm').addEventListener('submit', (e) => {
                e.preventDefault();

                try {
                    BakeSmartStore.marketing.addPromotion(
                        Object.fromEntries(new FormData(e.target).entries())
                    );

                    e.target.reset();
                    app.toast.success('Promoción registrada.');
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            search.addEventListener('input', render);

            function initializePage() {
                if (pageInitialized) return;
                pageInitialized = true;
                render();
            }

            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    initializePage();
                });
            });
        })();
    </script>
}