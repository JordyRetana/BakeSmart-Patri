@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["Title"] = "Detalle de pedido";
}
<div class="card">
    <div class="section-title">
        <div>
            <h2>Pedido #1012</h2>
            <div class="sub">María Gómez — Cake Red Velvet (1.5kg)</div>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <a class="btn-secondary" href="/Orders/Edit/1012">Editar</a>
            <a class="btn" href="/Orders">Volver</a>
        </div>
    </div>

    <div class="hr"></div>

    <div class="grid grid-3">
        <div class="card soft">
            <div class="muted" style="font-weight:900;">Estado</div>
            <div style="margin-top:10px;"><span class="pill good">En producción</span></div>
        </div>
        <div class="card soft">
            <div class="muted" style="font-weight:900;">Entrega</div>
            <div style="margin-top:10px;font-weight:950;font-size:18px;">2026-02-18</div>
        </div>
        <div class="card soft">
            <div class="muted" style="font-weight:900;">Total</div>
            <div style="margin-top:10px;font-weight:950;font-size:18px;">₡32 000</div>
        </div>
    </div>

    <div class="grid grid-2" style="margin-top:16px;">
        <div class="card soft">
            <div style="font-weight:950;">Notas</div>
            <div class="muted" style="margin-top:8px;font-weight:700;line-height:1.6;">
                Sin nueces • mensaje “Feliz cumple” • cobertura suave
            </div>
        </div>

        <div class="card soft">
            <div style="font-weight:950;">Acciones</div>
            <div class="muted" style="margin-top:8px;font-weight:700;line-height:1.6;">
                Editá estado, fecha y notas desde “Editar”.
            </div>
            <div style="margin-top:12px;">
                <a class="btn-secondary" href="/Production">Ver producción</a>
            </div>
        </div>
    </div>
</div>
