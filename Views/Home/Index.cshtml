@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inicio";
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var isAdmin = User?.IsInRole("Admin") ?? false;
    var isStaff = User?.IsInRole("Staff") ?? false;
    var isClient = User?.IsInRole("Cliente") ?? false;
}

@if (!isAuth)
{
    
    <section class="hero-section" style="background: linear-gradient(135deg, #fff9f9 0%, #fff5f8 100%); padding: 3rem 0; position: relative; overflow: hidden;">
        <div class="dark-mode-sensitive" style="position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.05) 0%, transparent 70%); border-radius: 50%;"></div>
        <div class="dark-mode-sensitive" style="position: absolute; bottom: -100px; left: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(139, 92, 246, 0.05) 0%, transparent 70%); border-radius: 50%;"></div>

        <div class="container" style="position: relative; z-index: 1;">
            <div style="max-width: 900px; margin: 0 auto; text-align: center;">
                <span class="badge badge-primary" style="font-size: 1rem; padding: 0.5rem 1.5rem; margin-bottom: 1.5rem; border-radius: 9999px;">
                    🧁 Bienvenidos a BakeSmart Patri
                </span>

                <h1 style="font-size: 3.5rem; font-weight: 800; line-height: 1.2; margin-bottom: 1rem;">
                    El sabor que
                    <span style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">endulza</span>
                    tus momentos
                </h1>

                <p style="font-size: 1.25rem; color: var(--text-light); margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                    Pastelería artesanal con amor y tradición. Cada creación está hecha con los mejores ingredientes y mucho corazón.
                </p>

                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem;">
                    <a href="/Catalog" class="btn btn-primary btn-lg">
                        <i class="fas fa-cookie-bite"></i>
                        Ver productos
                    </a>
                    <a href="/Account/Login" class="btn btn-outline btn-lg">
                        <i class="fas fa-user"></i>
                        Iniciar sesión
                    </a>
                </div>

                <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
                    <div style="width: 120px; height: 120px; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow); transform: rotate(-5deg);">
                        <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Pastel"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="width: 120px; height: 120px; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow); transform: rotate(2deg);">
                        <img src="https://images.unsplash.com/photo-1533134242443-d4fd215305ad?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Cheesecake"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="width: 120px; height: 120px; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow); transform: rotate(-3deg);">
                        <img src="https://images.unsplash.com/photo-1588195538326-c5b1e9f80a1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Cupcakes"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="width: 120px; height: 120px; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow); transform: rotate(5deg);">
                        <img src="https://images.unsplash.com/photo-1488477181946-6428a0291777?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Galletas"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                </div>

                <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 3rem; flex-wrap: wrap;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <div style="width: 32px; height: 32px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-leaf" style="color: var(--primary); font-size: 0.875rem;"></i>
                        </div>
                        <span class="text-muted">Ingredientes frescos</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <div style="width: 32px; height: 32px; background: var(--secondary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-heart" style="color: var(--secondary); font-size: 0.875rem;"></i>
                        </div>
                        <span class="text-muted">Hecho con amor</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <div style="width: 32px; height: 32px; background: #d1fae5; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-truck" style="color: var(--success); font-size: 0.875rem;"></i>
                        </div>
                        <span class="text-muted">Entrega a domicilio</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0; background: white;" class="stats-section">
        <div class="container">
            <div class="home-stats-grid">
                <div class="card" style="padding: 1.5rem; text-align: center; border: none; box-shadow: var(--shadow-sm);">
                    <div style="font-size: 2rem; color: var(--primary); margin-bottom: 0.5rem;">🎂</div>
                    <div style="font-size: 1.75rem; font-weight: 700; color: var(--primary);">500+</div>
                    <div class="text-muted" style="font-size: 0.875rem;">Pasteles horneados</div>
                </div>
                <div class="card" style="padding: 1.5rem; text-align: center; border: none; box-shadow: var(--shadow-sm);">
                    <div style="font-size: 2rem; color: var(--secondary); margin-bottom: 0.5rem;">😊</div>
                    <div style="font-size: 1.75rem; font-weight: 700; color: var(--secondary);">200+</div>
                    <div class="text-muted" style="font-size: 0.875rem;">Clientes felices</div>
                </div>
                <div class="card" style="padding: 1.5rem; text-align: center; border: none; box-shadow: var(--shadow-sm);">
                    <div style="font-size: 2rem; color: var(--success); margin-bottom: 0.5rem;">🚚</div>
                    <div style="font-size: 1.75rem; font-weight: 700; color: var(--success);">300+</div>
                    <div class="text-muted" style="font-size: 0.875rem;">Entregas a tiempo</div>
                </div>
                <div class="card" style="padding: 1.5rem; text-align: center; border: none; box-shadow: var(--shadow-sm);">
                    <div style="font-size: 2rem; color: var(--warning); margin-bottom: 0.5rem;">⭐</div>
                    <div style="font-size: 1.75rem; font-weight: 700; color: var(--warning);">4.9</div>
                    <div class="text-muted" style="font-size: 0.875rem;">Calificación</div>
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0; background: #fafafa;" class="featured-section">
        <div class="container">
            <div style="text-align: center; margin-bottom: 3rem;">
                <span class="badge badge-primary" style="margin-bottom: 1rem;">🍰 Lo más popular</span>
                <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Nuestros favoritos</h2>
                <p class="text-muted" style="max-width: 500px; margin: 0 auto;">Los productos que más aman nuestros clientes</p>
            </div>

            <div class="home-featured-grid">

                <div class="card" style="padding: 1rem;">
                    <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=250&q=80"
                         alt="Red Velvet"
                         style="width: 100%; height: 180px; object-fit: cover; border-radius: var(--radius); margin-bottom: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                        <h3 style="margin: 0; font-size: 1.25rem;">Red Velvet</h3>
                        <span class="badge badge-primary" style="font-size: 0.75rem;">Más vendido</span>
                    </div>
                    <p class="text-muted" style="font-size: 0.875rem; margin-bottom: 1rem;">Pastel de terciopelo rojo con crema de queso</p>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 700; font-size: 1.25rem; color: var(--primary);">₡32,000</span>
                        <a href="/Catalog/Details/1" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> Ver
                        </a>
                    </div>
                </div>

                
                <div class="card" style="padding: 1rem;">
                    <img src="https://images.unsplash.com/photo-1533134242443-d4fd215305ad?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=250&q=80"
                         alt="Cheesecake"
                         style="width: 100%; height: 180px; object-fit: cover; border-radius: var(--radius); margin-bottom: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                        <h3 style="margin: 0; font-size: 1.25rem;">Cheesecake</h3>
                        <span class="badge badge-success" style="font-size: 0.75rem;">Recomendado</span>
                    </div>
                    <p class="text-muted" style="font-size: 0.875rem; margin-bottom: 1rem;">Cheesecake de frutos rojos con base crocante</p>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 700; font-size: 1.25rem; color: var(--primary);">₡28,000</span>
                        <a href="/Catalog/Details/2" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> Ver
                        </a>
                    </div>
                </div>

                
                <div class="card" style="padding: 1rem;">
                    <img src="https://images.unsplash.com/photo-1588195538326-c5b1e9f80a1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=250&q=80"
                         alt="Cupcakes"
                         style="width: 100%; height: 180px; object-fit: cover; border-radius: var(--radius); margin-bottom: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                        <h3 style="margin: 0; font-size: 1.25rem;">Cupcakes</h3>
                        <span class="badge badge-warning" style="font-size: 0.75rem;">Especial</span>
                    </div>
                    <p class="text-muted" style="font-size: 0.875rem; margin-bottom: 1rem;">Cupcakes decorados, caja de 12 unidades</p>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 700; font-size: 1.25rem; color: var(--primary);">₡18,000</span>
                        <a href="/Catalog/Details/3" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> Ver
                        </a>
                    </div>
                </div>
            </div>

            <div style="text-align: center; margin-top: 2rem;">
                <a href="/Catalog" class="btn btn-outline">
                    Ver todos los productos <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0;">
        <div class="container">
            <div style="text-align: center; margin-bottom: 3rem;">
                <span class="badge badge-primary" style="margin-bottom: 1rem;">💬 Testimonios</span>
                <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Lo que dicen de nosotros</h2>
                <p class="text-muted">La opinión de nuestros clientes nos impulsa a mejorar cada día</p>
            </div>

            <div class="home-testimonials-grid">
                <div class="card">
                    <div style="display: flex; color: #fbbf24; margin-bottom: 1rem;">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-muted" style="font-style: italic; margin-bottom: 1.5rem;">"El pastel Red Velvet es increíble! Esponjoso, húmedo y con el punto perfecto de dulce."</p>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <div style="width: 40px; height: 40px; background: var(--gradient-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">MG</div>
                        <div>
                            <div style="font-weight: 600;">María Gómez</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Cliente frecuente</div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div style="display: flex; color: #fbbf24; margin-bottom: 1rem;">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-muted" style="font-style: italic; margin-bottom: 1.5rem;">"La torta personalizada para el cumpleaños de mi hija superó todas mis expectativas."</p>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <div style="width: 40px; height: 40px; background: var(--gradient-success); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">AS</div>
                        <div>
                            <div style="font-weight: 600;">Ana Solís</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Mamá repostera</div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div style="display: flex; color: #fbbf24; margin-bottom: 1rem;">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-muted" style="font-style: italic; margin-bottom: 1.5rem;">"Excelente servicio y calidad. Las galletas decoradas son perfectas para eventos."</p>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <div style="width: 40px; height: 40px; background: var(--gradient-warning); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">CR</div>
                        <div>
                            <div style="font-weight: 600;">Carlos R.</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Organizador de eventos</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0; background: #fafafa;" class="why-us-section">
        <div class="container">
            <div class="home-why-us-grid">
                <div>
                    <span class="badge badge-primary" style="margin-bottom: 1rem;">✨ Por qué nosotros</span>
                    <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Hecho con amor, entregado con pasión</h2>
                    <p class="text-muted" style="margin-bottom: 2rem;">Cada creación es única y especial, porque sabemos que detrás de cada pedido hay una celebración especial.</p>
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <i class="fas fa-check-circle" style="color: var(--success);"></i>
                            <span>Ingredientes frescos y naturales</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <i class="fas fa-check-circle" style="color: var(--success);"></i>
                            <span>Personalización total para cada ocasión</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <i class="fas fa-check-circle" style="color: var(--success);"></i>
                            <span>Entrega puntual en toda la ciudad</span>
                        </div>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <img src="https://images.unsplash.com/photo-1551024506-0bccd828d307?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&h=300&q=80"
                         alt="Pastel"
                         style="width: 100%; height: 150px; object-fit: cover; border-radius: var(--radius);">
                    <img src="https://images.unsplash.com/photo-1606313564200-e75d5e30476c?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&h=300&q=80"
                         alt="Brownie"
                         style="width: 100%; height: 150px; object-fit: cover; border-radius: var(--radius);">
                    <img src="https://images.unsplash.com/photo-1488477181946-6428a0291777?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&h=300&q=80"
                         alt="Galletas"
                         style="width: 100%; height: 150px; object-fit: cover; border-radius: var(--radius);">
                    <img src="https://images.unsplash.com/photo-1571115177094-24ec08c6433b?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&h=300&q=80"
                         alt="Torta"
                         style="width: 100%; height: 150px; object-fit: cover; border-radius: var(--radius);">
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0; background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white;">
        <div class="container" style="text-align: center;">
            <h2 style="color: white; font-size: 2.5rem; margin-bottom: 1rem;">¿Listo para probar?</h2>
            <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
                Haz tu pedido hoy y déjanos endulzar tu día
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <a href="/Catalog" class="btn btn-outline" style="background: white; color: var(--primary); border-color: white;">
                    Ver productos
                </a>
                <a href="/Account/Register" class="btn btn-outline" style="border-color: white; color: white;">
                    Crear cuenta
                </a>
            </div>
        </div>
    </section>
}
else if (isClient)
{
    

    <section class="hero-section" style="background: linear-gradient(135deg, #fff9f9 0%, #fff5f8 100%); padding: 4rem 0; position: relative; overflow: hidden;">
        <div class="container" style="position: relative; z-index: 1;">
            <div style="max-width: 800px; margin: 0 auto; text-align: center;">
                <span class="badge badge-primary" style="font-size: 1rem; padding: 0.5rem 1.5rem; margin-bottom: 1.5rem; border-radius: 9999px;">
                    🎉 ¡Hola, @(User?.Identity?.Name ?? "Cliente")!
                </span>

                <h1 style="font-size: 3rem; font-weight: 800; line-height: 1.2; margin-bottom: 1.5rem;">
                    Descubre nuevas
                    <span style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">inspiraciones</span>
                    para tus momentos especiales
                </h1>

                <p style="font-size: 1.2rem; color: var(--text-light); margin-bottom: 2rem;">
                    Explora nuestras novedades y encuentra el postre perfecto para cada ocasión.
                </p>

                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="/Catalog" class="btn btn-primary btn-lg">
                        <i class="fas fa-compass"></i>
                        Explorar catálogo
                    </a>
                    <a href="/Client" class="btn btn-outline btn-lg">
                        <i class="fas fa-user"></i>
                        Mi espacio personal
                    </a>
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0;">
        <div class="container">
            <div style="text-align: center; margin-bottom: 3rem;">
                <span class="badge badge-primary" style="margin-bottom: 1rem;">✨ Novedades</span>
                <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">¿Qué hay de nuevo?</h2>
                <p class="text-muted">Descubre nuestras últimas creaciones y promociones especiales</p>
            </div>

            <div class="grid grid-2" style="gap: 2rem;">
                
                <div class="card promo-card" style="background: linear-gradient(135deg, #fef3c7, #fde68a); border: none; overflow: hidden; position: relative;">
                    <div style="position: absolute; top: -20px; right: -20px; width: 150px; height: 150px; background: rgba(255,255,255,0.2); border-radius: 50%;"></div>
                    <div style="display: flex; align-items: center; gap: 2rem; position: relative; z-index: 1;">
                        <div>
                            <span class="badge badge-warning" style="margin-bottom: 0.5rem;">🔥 Promoción</span>
                            <h3 style="margin: 0.5rem 0; color: inherit;">2x1 en Cupcakes</h3>
                            <p class="text-muted">Válido todos los miércoles. Lleva 12 y paga 6.</p>
                            <a href="/Catalog?category=Cupcakes" class="btn btn-warning btn-sm">Aprovechar</a>
                        </div>
                        <img src="https://images.unsplash.com/photo-1588195538326-c5b1e9f80a1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Cupcakes"
                             style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover;">
                    </div>
                </div>

                
                <div class="card promo-card" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0); border: none; overflow: hidden; position: relative;">
                    <div style="position: absolute; top: -20px; right: -20px; width: 150px; height: 150px; background: rgba(255,255,255,0.2); border-radius: 50%;"></div>
                    <div style="display: flex; align-items: center; gap: 2rem; position: relative; z-index: 1;">
                        <div>
                            <span class="badge badge-success" style="margin-bottom: 0.5rem;">🎂 Nuevo</span>
                            <h3 style="margin: 0.5rem 0; color: inherit;">Torta Arcoíris</h3>
                            <p class="text-muted">Nuestra nueva torta de colores, ideal para cumpleaños</p>
                            <a href="/Catalog/Details/9" class="btn btn-success btn-sm">Conocer más</a>
                        </div>
                        <img src="https://images.unsplash.com/photo-1571115177094-24ec08c6433b?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&h=200&q=80"
                             alt="Torta Arcoíris"
                             style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover;">
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <section style="padding: 4rem 0; background: #fafafa;" class="gallery-section">
        <div class="container">
            <div style="text-align: center; margin-bottom: 3rem;">
                <span class="badge badge-primary" style="margin-bottom: 1rem;">📸 Inspiración</span>
                <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Momentos dulces</h2>
                <p class="text-muted">Clientes felices con nuestras creaciones</p>
            </div>

            <div class="home-gallery-grid">
                <img src="https://images.unsplash.com/photo-1551024506-0bccd828d307?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=400&q=80"
