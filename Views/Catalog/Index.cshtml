@model BakeSmartPatri.Models.CatalogIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Catalogo de Productos";
    var culture = new System.Globalization.CultureInfo("es-CR");
}

<div class="page-header" style="margin: 2rem 0 2.5rem 1.5rem;">
    <div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 5px; height: 50px; background: var(--gradient-primary); border-radius: 5px;"></div>
            <div>
                <h1 style="margin: 0; font-size: 2.5rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-book-open" style="color: var(--primary);"></i>
                    Nuestro Catalogo
                </h1>
                <p class="text-muted" style="margin-top: 0.5rem; font-size: 1rem; max-width: 600px;">
                    Descubre nuestra seleccion de productos artesanales, preparados con los mejores ingredientes y mucho amor
                </p>
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 1rem; margin-right: 1.5rem;">
        <span class="badge badge-primary" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
            <i class="fas fa-box-open"></i>
            @DateTime.Now.ToString("dddd, dd MMM", new System.Globalization.CultureInfo("es-ES"))
        </span>
    </div>
</div>

<div style="padding: 0 1.5rem;">
    <div class="catalog-toolbar" style="max-width: 600px; margin: 0 auto 2rem;">
        <div class="catalog-search-row" style="display: flex; gap: 0.5rem;">
            <div class="catalog-search-field" style="flex: 1; position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" class="input" id="searchProduct" placeholder="Buscar productos por nombre..." style="padding-left: 2.5rem;">
            </div>
            <button class="btn btn-primary catalog-search-button" type="button" onclick="filterProducts()">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>

    <div class="catalog-category-list" style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 3rem; flex-wrap: wrap;">
        <button class="btn btn-primary category-btn active" data-category="all" style="border-radius: 9999px;" type="button" onclick="filterCategory('all')">
            <i class="fas fa-th-large"></i>
            Todos
        </button>
        @foreach (var category in Model.Categories)
        {
            <button class="btn btn-outline category-btn" data-category="@category.Name" style="border-radius: 9999px;" type="button" onclick="filterCategory('@category.Name')">
                <i class="fas @category.Icon"></i>
                @category.Name
            </button>
        }
    </div>

    <div class="grid grid-3" id="productsGrid" style="gap: 1.5rem;">
        @foreach (var product in Model.Products)
        {
            <div class="card product-card" data-category="@product.Category" data-price="@product.UnitPrice" data-name="@product.Name">
                <div style="position: relative;">
                    <img src="@product.ImageUrl"
                         alt="@product.AltText"
                         onerror="this.src='/img/products/producto-sin-imagen.svg';"
                         style="width: 100%; height: 250px; object-fit: cover; border-radius: var(--radius);">
                    <span class="badge badge-primary" style="position: absolute; top: 1rem; right: 1rem;">@product.Category</span>
                    <button class="btn btn-ghost btn-sm favorite-btn" style="position: absolute; top: 1rem; left: 1rem; background: white; border-radius: 50%; width: 40px; height: 40px;" onclick="toggleFavorite(this)">
                        <i class="far fa-heart"></i>
                    </button>
                </div>

                <div style="margin-top: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; gap: .75rem;">
                        <h3 style="margin: 0;">@product.Name</h3>
                        <div style="display: flex; gap: 0.25rem; color: #fbbf24;">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                        </div>
                    </div>

                    <p class="text-muted" style="margin-bottom: 1rem;">
                        @product.Description
                    </p>

                    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                        <span class="badge"><i class="fas fa-barcode"></i> @product.Code</span>
                        <span class="badge"><i class="fas fa-box"></i> @product.Stock.ToString("0.##") @product.Unit</span>
                        @if (!string.IsNullOrWhiteSpace(product.Subcategory))
                        {
                            <span class="badge badge-info">@product.Subcategory</span>
                        }
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
                        <span style="font-weight: 700; font-size: 1.5rem; color: var(--primary);">@product.UnitPrice.ToString("C0", culture)</span>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="/Catalog/Details/@product.Id" class="btn btn-outline btn-sm" title="Ver detalles">
                                <i class="fas fa-eye"></i>
                            </a>
                            <button class="btn btn-primary btn-sm" type="button"
                                    data-id="@product.Id"
                                    data-name="@product.Name"
                                    data-price="@product.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    onclick="addProductButton(this)">
                                <i class="fas fa-shopping-cart"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="card" style="position: fixed; bottom: 20px; right: 20px; width: 300px; display: none; box-shadow: var(--shadow-xl); z-index: 1000;" id="cartSummary">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
        <h4 style="margin: 0; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fas fa-shopping-cart" style="color: var(--primary);"></i>
            Carrito
        </h4>
        <span class="badge badge-primary" id="cartCount">0</span>
    </div>
    <div id="cartItems" style="max-height: 200px; overflow-y: auto; margin-bottom: 0.5rem;"></div>
    <div style="display: flex; justify-content: space-between; font-weight: 700; margin-bottom: 0.5rem;">
        <span>Total:</span>
        <span id="cartTotal">₡0</span>
    </div>
    <a href="/Orders/Create" class="btn btn-primary btn-block">
        Finalizar pedido
    </a>
</div>

<script>
    let currentCategory = 'all';
    let cart = [];

    function filterCategory(category) {
        currentCategory = category;
        const buttons = document.querySelectorAll('.category-btn');
        buttons.forEach(btn => {
            const active = btn.dataset.category === category || (category === 'all' && btn.dataset.category === 'all');
            btn.classList.toggle('btn-primary', active);
            btn.classList.toggle('btn-outline', !active);
        });
        filterProducts();
    }

    function filterProducts() {
        const searchTerm = document.getElementById('searchProduct').value.toLowerCase();
        document.querySelectorAll('.product-card').forEach(product => {
            const matchesCategory = currentCategory === 'all' || product.dataset.category === currentCategory;
            const matchesSearch = !searchTerm || product.dataset.name.toLowerCase().includes(searchTerm);
            product.style.display = matchesCategory && matchesSearch ? 'block' : 'none';
        });
    }

    document.getElementById('searchProduct').addEventListener('input', app.utils.debounce(filterProducts, 250));

    function toggleFavorite(btn) {
        const icon = btn.querySelector('i');
        icon.classList.toggle('far');
        icon.classList.toggle('fas');
        if (icon.classList.contains('fas')) {
            icon.style.color = '#ec4899';
            app.toast.show('Agregado a favoritos', 'success');
        } else {
            icon.style.color = '';
        }
    }

    function addProductButton(button) {
        addToCart(Number(button.dataset.id), button.dataset.name, Number(button.dataset.price));
    }

    function addToCart(productId, name, price) {
        const existingItem = cart.find(item => item.id === productId);
        if (existingItem) {
            existingItem.quantity++;
        } else {
            cart.push({ id: productId, name, price, quantity: 1 });
        }

        updateCartDisplay();
        app.toast.show(`${name} agregado al carrito`, 'success');
    }

    function removeFromCart(productId) {
        cart = cart.filter(item => item.id !== productId);
        updateCartDisplay();
    }

    function updateCartDisplay() {
        const cartSummary = document.getElementById('cartSummary');
        const cartItems = document.getElementById('cartItems');
        const cartCount = document.getElementById('cartCount');
        const cartTotal = document.getElementById('cartTotal');
        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        const count = cart.reduce((sum, item) => sum + item.quantity, 0);

        cartSummary.style.display = cart.length ? 'block' : 'none';
        cartCount.textContent = count;
        cartTotal.textContent = `₡${total.toLocaleString('es-CR')}`;
        cartItems.innerHTML = cart.map(item => `
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem;padding:.5rem;border-bottom:1px solid var(--border);">
                <div><strong>${item.name}</strong><div class="text-muted" style="font-size:.75rem;">x${item.quantity}</div></div>
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <span>₡${(item.price * item.quantity).toLocaleString('es-CR')}</span>
                    <button class="btn btn-ghost btn-sm" onclick="removeFromCart(${item.id})" style="color:var(--danger);"><i class="fas fa-trash"></i></button>
                </div>
            </div>
        `).join('');
    }
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/catalog-index.css" asp-append-version="true" />
}
