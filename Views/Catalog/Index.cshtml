@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Catálogo de Productos";

    var categories = new[] {
        new { Id = 1, Name = "Pasteles", Icon = "fa-cake-candles" },
        new { Id = 2, Name = "Cupcakes", Icon = "fa-cupcake" },
        new { Id = 3, Name = "Postres", Icon = "fa-ice-cream" },
        new { Id = 4, Name = "Galletas", Icon = "fa-cookie" },
        new { Id = 5, Name = "Tortas", Icon = "fa-birthday-cake" },
        new { Id = 6, Name = "Bebidas", Icon = "fa-mug-hot" }
    };
}

<div class="page-header" style="margin: 2rem 0 2.5rem 1.5rem;">
    <div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 5px; height: 50px; background: var(--gradient-primary); border-radius: 5px;"></div>
            <div>
                <h1 style="margin: 0; font-size: 2.5rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-book-open" style="color: var(--primary);"></i>
                    Nuestro Catálogo
                </h1>
                <p class="text-muted" style="margin-top: 0.5rem; font-size: 1rem; max-width: 600px;">
                    Descubre nuestra selección de productos artesanales, preparados con los mejores ingredientes y mucho amor
                </p>
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 1rem; margin-right: 1.5rem;">
        <span class="badge badge-primary" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
            <i class="fas fa-box-open"></i>
            @DateTime.Now.ToString("dddd, dd MMM", new System.Globalization.CultureInfo("es-ES"))
        </span>
    </div>
</div>


<div style="padding: 0 1.5rem;">
    
    <div style="max-width: 600px; margin: 0 auto 2rem;">
        <div style="display: flex; gap: 0.5rem;">
            <div style="flex: 1; position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" class="input" id="searchProduct" placeholder="Buscar productos por nombre..." style="padding-left: 2.5rem;">
            </div>
            <button class="btn btn-primary" onclick="filterProducts()">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>

    
    <div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 3rem; flex-wrap: wrap;">
        <button class="btn btn-primary category-btn active" data-category="all" style="border-radius: 9999px;" onclick="filterCategory('all')">
            <i class="fas fa-th-large"></i>
            Todos
        </button>
        @foreach (var cat in categories)
        {
            <button class="btn btn-outline category-btn" data-category="@cat.Name" style="border-radius: 9999px;" onclick="filterCategory('@cat.Name')">
                <i class="fas @cat.Icon"></i>
                @cat.Name
            </button>
        }
    </div>

    
    <div class="grid grid-3" id="productsGrid" style="gap: 1.5rem;">
        
        <div class="card product-card" data-category="Pasteles" data-price="32000" data-name="Red Velvet">
