@model BakeSmartPatri.Models.CatalogProductDetailsViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Product.Name;
    var culture = new System.Globalization.CultureInfo("es-CR");
    var mainImage = Model.Images.FirstOrDefault()?.ImageUrl ?? Model.Product.ImageUrl;
}

<div class="page-shell catalog-details-page">
    <div style="margin-bottom:1.25rem;">
        <a href="/Catalog" class="btn btn-outline btn-sm">
            <i class="fas fa-arrow-left"></i>
            Volver al catalogo
        </a>
    </div>

    <section class="grid grid-2" style="gap:2rem;align-items:start;">
        <div class="card">
            <img id="mainProductImage" src="@mainImage" alt="@Model.Product.AltText" onerror="this.src='/img/products/producto-sin-imagen.svg';" style="width:100%;height:420px;object-fit:cover;border-radius:var(--radius);">
            @if (Model.Images.Count > 1)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(90px,1fr));gap:.75rem;margin-top:1rem;">
                    @foreach (var image in Model.Images)
                    {
                        <button type="button" class="btn btn-ghost" style="padding:0;border-radius:var(--radius);overflow:hidden;" onclick="setMainImage('@image.ImageUrl')">
                            <img src="@image.ImageUrl" alt="@image.AltText" onerror="this.src='/img/products/producto-sin-imagen.svg';" style="width:100%;height:90px;object-fit:cover;">
                        </button>
                    }
                </div>
            }
        </div>

        <div class="card">
            <span class="badge badge-primary">@Model.Product.Category</span>
            <h1 style="margin:1rem 0 .5rem;">@Model.Product.Name</h1>
            <p class="text-muted" style="line-height:1.7;">@Model.Product.Description</p>

            <div style="display:flex;align-items:center;gap:1rem;margin:1.5rem 0;flex-wrap:wrap;">
                <span style="font-size:2rem;font-weight:900;color:var(--primary);">@Model.Product.UnitPrice.ToString("C0", culture)</span>
                <span class="badge"><i class="fas fa-barcode"></i> @Model.Product.Code</span>
                <span class="badge badge-info"><i class="fas fa-box"></i> @Model.Product.Stock.ToString("0.##") @Model.Product.Unit</span>
            </div>

            <div class="grid grid-2" style="gap:1rem;margin-bottom:1.5rem;">
                <div class="card soft">
                    <div class="text-muted">Categoria</div>
                    <strong>@Model.Product.Category</strong>
                </div>
                <div class="card soft">
                    <div class="text-muted">Subcategoria</div>
                    <strong>@(Model.Product.Subcategory ?? "General")</strong>
                </div>
            </div>

            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <a href="/Orders/Create?product=@Model.Product.Id" class="btn btn-primary">
                    <i class="fas fa-shopping-cart"></i>
                    Crear pedido
                </a>
                <a href="/Catalog" class="btn btn-outline">
                    <i class="fas fa-book-open"></i>
                    Ver mas productos
                </a>
            </div>
        </div>
    </section>

    @if (Model.RelatedProducts.Count > 0)
    {
        <section style="margin-top:2rem;">
            <h2>Productos relacionados</h2>
            <div class="grid grid-3" style="gap:1.5rem;">
                @foreach (var product in Model.RelatedProducts)
                {
                    <article class="card product-card">
                        <img src="@product.ImageUrl" alt="@product.AltText" onerror="this.src='/img/products/producto-sin-imagen.svg';" style="width:100%;height:180px;object-fit:cover;border-radius:var(--radius);">
                        <h3 style="margin:1rem 0 .35rem;">@product.Name</h3>
                        <p class="text-muted">@product.Description</p>
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;">
                            <strong style="color:var(--primary);">@product.UnitPrice.ToString("C0", culture)</strong>
                            <a href="/Catalog/Details/@product.Id" class="btn btn-outline btn-sm">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>

<script>
    function setMainImage(url) {
        document.getElementById('mainProductImage').src = url;
    }
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/catalog-details.css" asp-append-version="true" />
}
