@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mis pedidos";
}
<div class="page-shell">
    <div class="page-header" style="margin-bottom:1.5rem; display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
        <div>
            <h1 style="margin:0; display:flex; align-items:center; gap:.75rem;"><i class="fas fa-box-open" style="color:var(--primary);"></i> Mis pedidos</h1>
            <p class="text-muted" style="margin:.35rem 0 0;">Consulta historial, filtra estados y paga pedidos pendientes.</p>
        </div>
        <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
            <input id="clientOrderSearch" class="form-control" placeholder="Buscar pedido o producto" />
            <a href="/Client/Track" class="btn btn-primary"><i class="fas fa-map-location-dot"></i> Seguimiento</a>
        </div>
    </div>
    <div class="card">
        <div class="table-container">
            <table class="table">
                <thead><tr><th>Pedido</th><th>Productos</th><th>Estado</th><th>Entrega</th><th>Pago</th><th>Total</th><th></th></tr></thead>
                <tbody id="clientOrdersTable"></tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        (() => {
            const userEmail = document.body.dataset.userEmail || 'cliente@demo.com';
            const search = document.getElementById('clientOrderSearch');

            function render() {
                const q = search.value.trim().toLowerCase();
                const rows = BakeSmartStore.orders.byClient(userEmail).filter(o => !q || String(o.id).includes(q) || o.items.some(i => i.name.toLowerCase().includes(q)));
                document.getElementById('clientOrdersTable').innerHTML = rows.map(o => `
                    <tr>
                        <td><strong>#${o.id}</strong><div class="text-muted" style="font-size:.8rem;">${new Date(o.createdAt).toLocaleString('es-CR')}</div></td>
                        <td>${o.items.map(i => `${i.quantity} x ${i.name}`).join('<br>')}</td>
                        <td><span class="badge badge-primary">${o.status}</span></td>
                        <td>${new Date(o.deliveryDate).toLocaleDateString('es-CR')}</td>
                        <td><span class="badge ${o.paymentStatus === 'Pagado' ? 'badge-success' : 'badge-warning'}">${o.paymentStatus}</span></td>
                        <td>${app.utils.formatCurrency(o.total)}</td>
                        <td class="text-right">
                            ${o.paymentStatus !== 'Pagado' ? `<button class="btn btn-outline btn-sm" onclick="payClientOrder(${o.id})">Pagar</button>` : ''}
                            <a class="btn btn-outline btn-sm" href="/Client/Track">Ver mapa</a>
                        </td>
                    </tr>
                `).join('') || `<tr><td colspan="7" class="text-center text-muted">No hay pedidos registrados.</td></tr>`;
            }

            window.payClientOrder = (id) => {
                try {
                    BakeSmartStore.orders.markPaid(id, 'SINPE Móvil');
                    app.toast.success('Pago registrado. Tu pedido fue enviado al flujo operativo.');
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            search.addEventListener('input', render);
            render();
        })();
    </script>
}
