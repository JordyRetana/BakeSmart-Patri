@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mi perfil";
    var nameLabel = User?.Identity?.Name ?? "Cliente";
    var emailLabel = User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "cliente@demo.com";
}

<div class="page-shell client-profile-page">
    <div class="page-header client-profile-header">
        <div>
            <h1 class="client-profile-title">
                <i class="fas fa-user-pen"></i>
                Mi perfil
            </h1>
            <p class="text-muted client-profile-subtitle">Mantén tus datos de entrega listos para que cada pedido salga con menos pasos.</p>
        </div>

        <div class="client-profile-actions">
            <a href="/Client/Orders" class="btn btn-outline">
                <i class="fas fa-box"></i>
                Mis pedidos
            </a>
            <a href="/Client/Track" class="btn btn-primary">
                <i class="fas fa-route"></i>
                Seguimiento
            </a>
        </div>
    </div>

    <div class="client-profile-layout">
        <section class="card client-profile-card">
            <div class="client-profile-avatar-wrap">
                <div class="client-profile-avatar" id="profileInitials">CL</div>
                <div>
                    <h2 id="profileNameTitle">@nameLabel</h2>
                    <p class="text-muted" id="profileEmailTitle">@emailLabel</p>
                </div>
            </div>

            <div class="client-profile-stats">
                <div>
                    <span>Pedidos</span>
                    <strong id="profileOrdersCount">0</strong>
                </div>
                <div>
                    <span>Activos</span>
                    <strong id="profileActiveOrders">0</strong>
                </div>
                <div>
                    <span>Total</span>
                    <strong id="profileSpent">₡0</strong>
                </div>
            </div>

            <div class="client-profile-address-box">
                <span>Dirección predeterminada</span>
                <strong id="profileDefaultAddress">Escazú, San José</strong>
            </div>
        </section>

        <section class="card client-profile-form-card">
            <div class="client-profile-section-header">
                <h3>Datos del cliente</h3>
                <span class="badge badge-primary">Local</span>
            </div>

            <form id="clientProfileForm" class="client-profile-form">
                <div class="client-profile-form-grid">
                    <div class="form-group">
                        <label>Nombre completo</label>
                        <input class="form-control" name="name" value="@nameLabel" required />
                    </div>
                    <div class="form-group">
                        <label>Correo</label>
                        <input class="form-control" name="email" type="email" value="@emailLabel" required />
                    </div>
                </div>

                <div class="client-profile-form-grid">
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input class="form-control" name="phone" value="8888-3333" required />
                    </div>
                    <div class="form-group">
                        <label>Método de pago preferido</label>
                        <select class="form-control" name="paymentMethod">
                            <option>SINPE Móvil</option>
                            <option>Tarjeta</option>
                            <option>Efectivo</option>
                            <option>Pendiente</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Dirección frecuente</label>
                    <input class="form-control" name="address" value="Escazú, San José" required />
                </div>

                <div class="form-group">
                    <label>Notas para entregas</label>
                    <textarea class="form-control" name="notes" rows="3" placeholder="Ej: llamar al llegar, dejar en recepción, horario preferido."></textarea>
                </div>

                <button class="btn btn-primary client-profile-save" type="submit">
                    <i class="fas fa-floppy-disk"></i>
                    Guardar perfil
                </button>
            </form>
        </section>
    </div>

    <section class="card client-profile-history-card">
        <div class="client-profile-section-header">
            <h3>Últimos movimientos</h3>
            <a href="/Client/Orders" class="btn btn-outline btn-sm">Ver todos</a>
        </div>
        <div id="profileRecentOrders" class="client-profile-history"></div>
    </section>
</div>

<style>
    .client-profile-page {
        display: grid;
        gap: 1rem;
    }

    .client-profile-page,
    .client-profile-page * {
        min-width: 0;
    }

    .client-profile-header,
    .client-profile-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .client-profile-title {
        margin: 0;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .client-profile-title i {
        color: var(--primary);
    }

    .client-profile-subtitle {
        margin: .35rem 0 0;
    }

    .client-profile-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .client-profile-layout {
        display: grid;
        grid-template-columns: minmax(280px, .75fr) minmax(0, 1.25fr);
        gap: 1rem;
        align-items: start;
    }

    .client-profile-card,
    .client-profile-form-card,
    .client-profile-history-card {
        padding: 1.15rem;
    }

    .client-profile-card:hover,
    .client-profile-form-card:hover,
    .client-profile-history-card:hover {
        transform: none;
        box-shadow: var(--shadow-sm);
        border-color: var(--border);
    }

    .client-profile-card:hover::after,
    .client-profile-form-card:hover::after,
    .client-profile-history-card:hover::after {
        opacity: 0;
    }

    .client-profile-avatar-wrap {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .client-profile-avatar {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: #fff;
        font-weight: 800;
        font-size: 1.25rem;
        box-shadow: var(--shadow-sm);
    }

    .client-profile-avatar-wrap h2 {
        margin: 0;
        font-size: 1.3rem;
    }

    .client-profile-avatar-wrap p {
        margin: .2rem 0 0;
    }

    .client-profile-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .6rem;
        margin-bottom: .9rem;
    }

    .client-profile-stats div,
    .client-profile-address-box,
    .client-profile-history-item {
        padding: .85rem;
        border-radius: 14px;
        background: var(--bg-alt);
        border: 1px solid var(--border);
    }

    .client-profile-stats span,
    .client-profile-address-box span {
        display: block;
        margin-bottom: .25rem;
        color: var(--text-muted);
        font-size: .74rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .client-profile-stats strong,
    .client-profile-address-box strong {
        color: var(--text);
    }

    .client-profile-form {
        display: grid;
        gap: .95rem;
        margin-top: 1rem;
    }

    .client-profile-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .client-profile-form label {
        font-weight: 700;
        font-size: .82rem;
        color: var(--text);
    }

    .client-profile-save {
        width: 100%;
    }

    .client-profile-history {
        display: grid;
        gap: .75rem;
        margin-top: 1rem;
    }

    .client-profile-history-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: center;
    }

    .client-profile-history-item strong {
        color: var(--text);
    }

    body.dark .client-profile-stats div,
    body.dark .client-profile-address-box,
    body.dark .client-profile-history-item {
        background: #111827;
        border-color: #334155;
    }

    @@media (max-width: 980px) {
        .client-profile-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 680px) {
        .client-profile-actions,
        .client-profile-actions .btn {
            width: 100%;
        }

        .client-profile-form-grid,
        .client-profile-stats,
        .client-profile-history-item {
            grid-template-columns: 1fr;
        }
    }
</style>

@section Scripts {
    <script>
        (() => {
            const userEmail = document.body.dataset.userEmail || '@emailLabel';
            const form = document.getElementById('clientProfileForm');
            const storageKey = `bakesmart.client.profile.${userEmail}`;

            function initials(name) {
                return name
                    .split(' ')
                    .filter(Boolean)
                    .slice(0, 2)
                    .map(part => part[0])
                    .join('')
                    .toUpperCase() || 'CL';
            }

            function profileFromForm() {
                return Object.fromEntries(new FormData(form).entries());
            }

            function applyProfile(profile) {
                if (!profile) return;
                Object.entries(profile).forEach(([key, value]) => {
                    if (form.elements[key]) form.elements[key].value = value;
                });
            }

            function render() {
                const profile = profileFromForm();
                const orders = BakeSmartStore.orders.byClient(userEmail);
                const total = orders.reduce((acc, order) => acc + order.total, 0);

                document.getElementById('profileInitials').textContent = initials(profile.name);
                document.getElementById('profileNameTitle').textContent = profile.name;
                document.getElementById('profileEmailTitle').textContent = profile.email;
                document.getElementById('profileDefaultAddress').textContent = profile.address;
                document.getElementById('profileOrdersCount').textContent = orders.length;
                document.getElementById('profileActiveOrders').textContent = orders.filter(order => order.status !== 'Entregado').length;
                document.getElementById('profileSpent').textContent = app.utils.formatCurrency(total);

                document.getElementById('profileRecentOrders').innerHTML = orders.slice(0, 4).map(order => `
                    <div class="client-profile-history-item">
                        <div>
                            <strong>#${order.id} · ${order.items.map(item => item.name).join(', ')}</strong>
                            <div class="text-muted">${order.status} · ${new Date(order.deliveryDate).toLocaleDateString('es-CR')}</div>
                        </div>
                        <span class="badge ${order.paymentStatus === 'Pagado' ? 'badge-success' : 'badge-warning'}">${order.paymentStatus}</span>
                    </div>
                `).join('') || `
                    <div class="client-profile-history-item">
                        <div>
                            <strong>Aún no tienes pedidos</strong>
                            <div class="text-muted">Cuando registres uno, aparecerá aquí.</div>
                        </div>
                        <a href="/Client" class="btn btn-primary btn-sm">Crear pedido</a>
                    </div>
                `;
            }

            try {
                applyProfile(JSON.parse(localStorage.getItem(storageKey) || 'null'));
            } catch {
                localStorage.removeItem(storageKey);
            }

            form.addEventListener('submit', (event) => {
                event.preventDefault();
                localStorage.setItem(storageKey, JSON.stringify(profileFromForm()));
                app.toast.success('Perfil actualizado para este navegador.');
                render();
            });

            form.addEventListener('input', render);
            render();
        })();
    </script>
}
