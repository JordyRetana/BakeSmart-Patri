
@section Styles {
    <link rel="stylesheet" href="~/css/pages/client-index.css" asp-append-version="true" />
}
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mi panel";
    var nameLabel = User?.Identity?.Name ?? "Cliente";
}

<div class="page-shell client-dashboard-page client-dashboard-page--loading" id="clientDashboardPage">
    <div class="page-header client-dashboard-header">
        <div>
            <h1 class="client-dashboard-title">
                <i class="fas fa-smile"></i>
                Hola, @nameLabel
            </h1>
            <p class="text-muted client-dashboard-subtitle">
                Desde aquí puedes registrar pedidos, pagar, seguir entregas y editar tu perfil.
            </p>
        </div>

        <div class="client-dashboard-actions">
            <a href="/Client/Orders" class="btn btn-primary">
                <i class="fas fa-box"></i>
                Mis pedidos
            </a>
            <a href="/Client/Track" class="btn btn-outline">
                <i class="fas fa-map-location-dot"></i>
                Seguimiento
            </a>
        </div>
    </div>

    <div class="grid grid-3 client-dashboard-kpis">
        <div class="card client-dashboard-kpi-card">
            <div class="text-muted">Pedidos del cliente</div>
            <h2 id="clientOrderCount"></h2>
        </div>

        <div class="card client-dashboard-kpi-card">
            <div class="text-muted">Total gastado</div>
            <h2 id="clientSpent"></h2>
        </div>

        <div class="card client-dashboard-kpi-card">
            <div class="text-muted">Pedidos activos</div>
            <h2 id="clientActive"></h2>
        </div>
    </div>

    <div class="client-dashboard-main-grid">
        <div class="card client-dashboard-order-card">
            <div class="client-dashboard-section-header">
                <h3 class="client-dashboard-section-title">Pedido rápido desde el sitio web</h3>
            </div>

            <form id="quickOrderForm" class="client-dashboard-form">
                <div class="client-dashboard-form-grid">
                    <div class="client-dashboard-form-block">
                        <label>Nombre</label>
                        <input class="form-control" name="customerName" value="@nameLabel" required />
                    </div>

                    <div class="client-dashboard-form-block">
                        <label>Correo</label>
                        <input class="form-control"
                               name="customerEmail"
                               type="email"
                               value="@(User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")"
                               required />
                    </div>
                </div>

                <div class="client-dashboard-form-grid">
                    <div class="client-dashboard-form-block">
                        <label>Teléfono</label>
                        <input class="form-control" name="customerPhone" value="88883333" required />
                    </div>

                    <div class="client-dashboard-form-block">
                        <label>Fecha de entrega</label>
                        <input class="form-control" name="deliveryDate" type="date" required />
                    </div>
                </div>

                <div class="client-dashboard-form-block">
                    <label>Método de entrega</label>
                    <select class="form-control" name="deliveryMethod" id="quickDeliveryMethod">
                        <option value="domicilio">A domicilio</option>
                        <option value="retiro">Retiro en tienda</option>
                    </select>
                </div>

                <div id="quickDeliveryMapBlock" class="client-dashboard-form-block">
                    <label>Dirección de entrega</label>
                    <div style="margin-bottom:.75rem;">
                        <select class="form-control" id="quickSavedAddress">
                            <option value="">Usar direccion predeterminada o seleccionar en el mapa</option>
                        </select>
                    </div>
                    <input type="hidden" name="address" id="quickAddress" />
                    <input type="hidden" name="destinationLatitude" id="quickLat" />
                    <input type="hidden" name="destinationLongitude" id="quickLng" />
                    <input type="hidden" name="customerAddressId" id="quickCustomerAddressId" />
                    <div id="quickOrderMapPicker"></div>
                </div>

                <div class="client-dashboard-product-grid">
                    <div class="client-dashboard-form-block">
                        <label>Producto</label>
                        <select class="form-control" name="productId" id="quickOrderProduct"></select>
                    </div>

                    <div class="client-dashboard-form-block">
                        <label>Cantidad</label>
                        <input class="form-control" name="quantity" type="number" min="1" value="1" required />
                    </div>

                    <div class="client-dashboard-form-block">
                        <label>Método de pago</label>
                        <select class="form-control" name="paymentMethod">
                            <option>Pendiente</option>
                            <option>Efectivo</option>
                            <option>SINPE Móvil</option>
                            <option>Tarjeta</option>
                        </select>
                    </div>
                </div>

                <div class="client-dashboard-form-block">
                    <label>Notas</label>
                    <textarea class="form-control" name="notes" rows="3" placeholder="Detalles del pedido"></textarea>
                </div>

                <button class="btn btn-primary client-dashboard-submit-btn" type="submit" id="quickOrderSubmitBtn">
                    <i class="fas fa-paper-plane"></i>
                    Registrar pedido
                </button>
            </form>
        </div>

        <div class="card client-dashboard-miniorders-card">
            <div class="client-dashboard-section-header">
                <h3 class="client-dashboard-section-title">Últimos pedidos</h3>
            </div>

            <div class="table-container client-dashboard-table-wrap">
                <table class="table client-dashboard-table">
                    <thead>
                        <tr>
                            <th>Pedido</th>
                            <th>Estado</th>
                            <th>Pago</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody id="clientMiniOrders"></tbody>
                </table>
            </div>

            <div class="client-dashboard-footer-actions">
                <a href="/Client/Profile" class="btn btn-outline">
                    <i class="fas fa-user-pen"></i>
                    Editar perfil
                </a>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/js/bakesmart-map-picker.js" asp-append-version="true"></script>
    <script>
        (() => {
            const page = document.getElementById('clientDashboardPage');
            const userEmail = document.body.dataset.userEmail || '';
            const form = document.getElementById('quickOrderForm');
            const productSelect = document.getElementById('quickOrderProduct');
            const submitBtn = document.getElementById('quickOrderSubmitBtn');
            const deliveryMethod = document.getElementById('quickDeliveryMethod');
            const deliveryMapBlock = document.getElementById('quickDeliveryMapBlock');
            const savedAddressSelect = document.getElementById('quickSavedAddress');

            let pageInitialized = false;
            let productsLoaded = false;
            let quickMapPicker;

            function showPage() {
                page.classList.remove('client-dashboard-page--loading');
                page.classList.add('client-dashboard-page--ready');
            }

            async function fillProductsOnce() {
                if (productsLoaded) return;
                await BakeSmartStore.refresh();

                const products = BakeSmartStore.inventory.list().filter(p => p.active && p.stock > 0);
                productSelect.innerHTML = products.map(p =>
                    `<option value="${p.id}">${p.description} - ${app.utils.formatCurrency(p.price)}</option>`
                ).join('');

                productsLoaded = true;
            }

            function renderSummary() {
                const orders = BakeSmartStore.orders.byClient(userEmail);
                const total = orders.reduce((acc, x) => acc + x.total, 0);

                document.getElementById('clientOrderCount').textContent = orders.length;
                document.getElementById('clientSpent').textContent = app.utils.formatCurrency(total);
                document.getElementById('clientActive').textContent = orders.filter(x => x.status !== 'Entregado').length;

                document.getElementById('clientMiniOrders').innerHTML = orders.slice(0, 5).map(o => `
                    <tr>
                        <td>
                            <strong>#${o.id}</strong>
                            <div class="text-muted" style="font-size:.8rem;">${o.items.map(i => i.name).join(', ')}</div>
                        </td>
                        <td>
                            <span class="badge badge-primary">${o.status}</span>
                        </td>
                        <td>
                            <span class="badge ${o.paymentStatus === 'Pagado' ? 'badge-success' : 'badge-warning'}">
                                ${o.paymentStatus}
                            </span>
                        </td>
                        <td>${app.utils.formatCurrency(o.total)}</td>
                    </tr>
                `).join('') || `
                    <tr>
                        <td colspan="4" class="text-center text-muted">No tienes pedidos aún.</td>
                    </tr>
                `;
            }

            function toggleQuickDelivery() {
                const isPickup = deliveryMethod.value === 'retiro';
                deliveryMapBlock.style.display = isPickup ? 'none' : 'block';
            }

            async function initQuickMap() {
                await BakeSmartStore.refresh();
                const config = BakeSmartStore.pos.config();
                let defaultAddress = null;

                try {
                    defaultAddress = await BakeSmartStore.loadDefaultAddress();
                    if (defaultAddress) {
                        const option = document.createElement('option');
                        option.value = String(defaultAddress.id);
                        option.textContent = `${defaultAddress.label} - ${defaultAddress.addressLine}`;
                        option.dataset.address = defaultAddress.addressLine;
                        option.dataset.lat = defaultAddress.latitude ?? '';
                        option.dataset.lng = defaultAddress.longitude ?? '';
                        option.selected = true;
                        savedAddressSelect.appendChild(option);
                    }
                } catch (_) { /* no saved address yet */ }

                quickMapPicker = await BakeSmartMapPicker.create('quickOrderMapPicker', {
                    address: defaultAddress?.addressLine || '',
                    lat: defaultAddress?.latitude || config.originLatitude,
                    lng: defaultAddress?.longitude || config.originLongitude,
                    onChange(values) {
                        document.getElementById('quickAddress').value = values.address || '';
                        document.getElementById('quickLat').value = values.lat ?? '';
                        document.getElementById('quickLng').value = values.lng ?? '';
                        document.getElementById('quickCustomerAddressId').value = '';
                        savedAddressSelect.value = '';
                    }
                });

                if (defaultAddress) {
                    document.getElementById('quickAddress').value = defaultAddress.addressLine;
                    document.getElementById('quickLat').value = defaultAddress.latitude ?? '';
                    document.getElementById('quickLng').value = defaultAddress.longitude ?? '';
                    document.getElementById('quickCustomerAddressId').value = defaultAddress.id;
                }
            }

            savedAddressSelect.addEventListener('change', () => {
                const option = savedAddressSelect.selectedOptions[0];
                if (!option || !option.value) return;
                quickMapPicker.setValues({
                    address: option.dataset.address,
                    lat: option.dataset.lat,
                    lng: option.dataset.lng
                });
                document.getElementById('quickAddress').value = option.dataset.address;
                document.getElementById('quickLat').value = option.dataset.lat;
                document.getElementById('quickLng').value = option.dataset.lng;
                document.getElementById('quickCustomerAddressId').value = option.value;
            });

            deliveryMethod.addEventListener('change', toggleQuickDelivery);

            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const data = Object.fromEntries(new FormData(form).entries());
                const isPickup = data.deliveryMethod === 'retiro';

                if (!isPickup && quickMapPicker) {
                    const mapValues = quickMapPicker.applyToFields({
                        address: 'quickAddress',
                        lat: 'quickLat',
                        lng: 'quickLng'
                    });
                    data.address = mapValues.address || data.address;
                    data.destinationLatitude = mapValues.lat;
                    data.destinationLongitude = mapValues.lng;
                }

                if (!isPickup && quickMapPicker && !quickMapPicker.isValid()) {
                    app.toast.error('Seleccione una ubicacion valida de entrega en el mapa.');
                    return;
                }

                try {
                    submitBtn.disabled = true;
                    const product = BakeSmartStore.inventory.list().find(p => Number(p.id) === Number(data.productId));
                    if (!product) throw new Error('Producto no disponible.');

                    const quantity = Number(data.quantity || 1);
                    const subtotal = Number(product.price) * quantity;
                    const taxRate = Number(BakeSmartStore.pos.config().iva || 0);
                    const tax = subtotal * taxRate;
                    const total = subtotal + tax;

                    await BakeSmartStore.createOrder({
                        customerName: data.customerName,
                        email: data.customerEmail,
                        phone: data.customerPhone,
                        productId: Number(data.productId),
                        quantity,
                        unitPrice: Number(product.price),
                        subtotal,
                        tax,
                        total,
                        deliveryDate: data.deliveryDate,
                        address: isPickup ? null : data.address,
                        notes: data.notes || null,
                        paymentMethod: data.paymentMethod,
                        destinationLatitude: isPickup ? null : Number(data.destinationLatitude),
                        destinationLongitude: isPickup ? null : Number(data.destinationLongitude),
                        customerAddressId: isPickup ? null : (data.customerAddressId ? Number(data.customerAddressId) : null),
                        deliveryMethod: data.deliveryMethod
                    });

                    await BakeSmartStore.refresh();
                    app.toast.success('Pedido registrado correctamente.');
                    renderSummary();
                    form.quantity.value = 1;
                    form.notes.value = '';
                } catch (error) {
                    app.toast.error(error.message);
                } finally {
                    submitBtn.disabled = false;
                }
            });

            async function initializePage() {
                if (pageInitialized) return;
                pageInitialized = true;

                const tomorrow = new Date(Date.now() + 86400000).toISOString().slice(0, 10);
                form.deliveryDate.value = tomorrow;

                await fillProductsOnce();
                await initQuickMap();
                toggleQuickDelivery();
                renderSummary();

                requestAnimationFrame(() => {
                    showPage();
                });
            }

            app.page.ready(() => initializePage());
        })();
    </script>
}
