@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Crear cuenta";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account-register.css" asp-append-version="true" />
}

<div class="auth-page-shell register-page">
    <div class="card auth-card register-card">
        <div class="auth-hero">
            <div class="auth-logo-wrap">
                <i class="fas fa-user-plus"></i>
            </div>
            <h2 class="auth-title">Crear cuenta</h2>
            <p class="text-muted auth-subtitle">Registra tu usuario para hacer pedidos y consultar seguimiento.</p>
        </div>

        @if (!string.IsNullOrEmpty(TempData["Toast"]?.ToString()))
        {
            <div class="alert alert-error auth-alert">
                <i class="fas fa-exclamation-circle"></i>
                @TempData["Toast"]
            </div>
        }

        <form method="post" action="/Account/Register" class="register-form" id="registerForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="register-grid">
                <div class="input-group">
                    <label class="input-label"><i class="fas fa-user"></i> Nombre</label>
                    <input class="input" name="firstName" required autocomplete="given-name" />
                </div>

                <div class="input-group">
                    <label class="input-label"><i class="fas fa-user"></i> Apellidos</label>
                    <input class="input" name="lastName" required autocomplete="family-name" />
                </div>

                <div class="input-group">
                    <label class="input-label"><i class="fas fa-envelope"></i> Correo electronico</label>
                    <input class="input" type="email" name="email" required autocomplete="email" />
                </div>

                <div class="input-group">
                    <label class="input-label"><i class="fas fa-phone"></i> Telefono</label>
                    <input class="input" name="phone" autocomplete="tel" />
                </div>

                <div class="input-group register-full">
                    <label class="input-label"><i class="fas fa-location-dot"></i> Direccion</label>
                    <input class="input" name="addressLine" autocomplete="street-address" />
                </div>

                <div class="input-group">
                    <label class="input-label"><i class="fas fa-lock"></i> Contraseña</label>
                    <input class="input" type="password" name="password" minlength="8" required autocomplete="new-password" />
                </div>

                <div class="input-group">
                    <label class="input-label"><i class="fas fa-lock"></i> Confirmar contraseña</label>
                    <input class="input" type="password" name="confirmPassword" minlength="8" required autocomplete="new-password" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg register-submit-btn" id="registerSubmitBtn">
                <i class="fas fa-user-check"></i>
                Crear cuenta
            </button>
        </form>
    </div>

    <div class="card auth-help-card">
        <div class="auth-help-row">
            <i class="fas fa-shield-halved"></i>
            <div>
                <p><strong>Seguridad:</strong> La contraseña se guarda hasheada con PBKDF2.</p>
                <p class="text-muted">El usuario nuevo queda registrado con rol Cliente.</p>
            </div>
        </div>
        <a href="/Account/Login" class="btn btn-outline btn-sm">Ya tengo cuenta</a>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const form = document.getElementById('registerForm');
    const submit = document.getElementById('registerSubmitBtn');
    if (!form || !submit) return;

    form.addEventListener('submit', () => {
        submit.disabled = true;
        submit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creando cuenta...';
    }, { once: true });
})();
</script>
}
