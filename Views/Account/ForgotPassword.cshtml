@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="login-page-shell">
    <div class="card login-card">
        <div class="login-hero">
            <div class="login-logo-wrap">
                <i class="fas fa-key"></i>
            </div>

            <h2 class="login-title">Recuperar contraseña</h2>
            <p class="text-muted login-subtitle">
                Ingresa tu correo para restablecer tu contraseña.
            </p>
        </div>

        @if (!string.IsNullOrEmpty(TempData["ToastError"]?.ToString()))
        {
            <div class="alert alert-error login-alert">
                <i class="fas fa-exclamation-circle"></i>
                @TempData["ToastError"]
            </div>
        }

        <form method="post" action="/Account/ForgotPassword" class="login-form">
            @Html.AntiForgeryToken()

            <div class="input-group">
                <label class="input-label">
                    <i class="fas fa-envelope"></i>
                    Correo electrónico
                </label>
                <input type="email"
                       class="input"
                       name="email"
                       placeholder="tu@correo.com"
                       required
                       autocomplete="email" />
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg login-submit-btn">
                <i class="fas fa-paper-plane"></i>
                Restablecer contraseña
            </button>

            <a href="/Account/Login" class="btn btn-outline btn-block">
                <i class="fas fa-arrow-left"></i>
                Volver al inicio de sesión
            </a>
        </form>
    </div>
</div>
