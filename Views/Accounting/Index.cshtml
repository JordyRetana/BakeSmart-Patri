@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Contabilidad";
}

<div class="page-shell accounting-page">
    <div class="page-header accounting-header">
        <div>
            <h1 class="accounting-title">
                <i class="fas fa-calculator"></i>
                Contabilidad básica
            </h1>
            <p class="text-muted accounting-subtitle">
                Asientos por ventas, gastos, pagos a proveedores, cierre diario y conciliación.
            </p>
        </div>
    </div>

    <div class="grid grid-4 accounting-kpi-grid">
        <div class="card accounting-kpi-card">
            <div class="text-muted">Asientos</div>
            <h2 id="accEntriesCount"></h2>
        </div>

        <div class="card accounting-kpi-card">
            <div class="text-muted">Gastos</div>
            <h2 id="accExpensesCount"></h2>
        </div>

        <div class="card accounting-kpi-card">
            <div class="text-muted">Pagos proveedores</div>
            <h2 id="accPaymentsCount"></h2>
        </div>

        <div class="card accounting-kpi-card">
            <div class="text-muted">Estado conciliación</div>
            <h2 id="accReconStatus"></h2>
        </div>
    </div>

    <div class="accounting-main-grid">
        <div class="card accounting-actions-card">
            <div class="accounting-block">
                <div class="accounting-section-header">
                    <h3 class="accounting-section-title">Registrar gasto</h3>
                </div>

                <form id="expenseForm" class="accounting-form">
                    <div class="accounting-form-block">
                        <label>Descripción del gasto</label>
                        <input class="form-control" name="description" placeholder="Descripción del gasto" required />
                    </div>

                    <div class="accounting-form-block">
                        <label>Monto</label>
                        <input class="form-control" name="amount" type="number" min="0.01" step="0.01" placeholder="Monto" required />
                    </div>

                    <div class="accounting-form-block">
                        <label>Cuenta contable</label>
                        <input class="form-control" name="account" placeholder="Cuenta contable" required />
                    </div>

                    <button class="btn btn-primary accounting-submit-btn" type="submit">
                        Registrar gasto
                    </button>
                </form>
            </div>

            <div class="hr"></div>

            <div class="accounting-block">
                <div class="accounting-section-header">
                    <h3 class="accounting-section-title">Pago a proveedor</h3>
                </div>

                <form id="supplierPaymentForm" class="accounting-form">
                    <div class="accounting-form-block">
                        <label>Proveedor</label>
                        <input class="form-control" name="supplier" placeholder="Proveedor" required />
                    </div>

                    <div class="accounting-form-block">
                        <label>Monto</label>
                        <input class="form-control" name="amount" type="number" min="0.01" step="0.01" placeholder="Monto" required />
                    </div>

                    <div class="accounting-form-block">
                        <label>Cuenta contable</label>
                        <input class="form-control" name="account" placeholder="Cuenta contable" required />
                    </div>

                    <div class="accounting-form-block">
                        <label>Método</label>
                        <select class="form-control" name="method">
                            <option>Transferencia</option>
                            <option>SINPE</option>
                            <option>Tarjeta</option>
                        </select>
                    </div>

                    <button class="btn btn-outline accounting-submit-btn" type="submit">
                        Registrar pago
                    </button>
                </form>
            </div>

            <div class="hr"></div>

            <div class="accounting-action-buttons">
                <button class="btn btn-primary" id="accReconcileBtn" type="button">
                    Conciliar operaciones
                </button>
                <button class="btn btn-outline" id="accCloseBtn" type="button">
                    Cierre diario
                </button>
            </div>
        </div>

        <div class="card accounting-entries-card">
            <div class="accounting-section-header">
                <h3 class="accounting-section-title">Asientos contables</h3>
            </div>

            <div class="table-container accounting-table-wrap">
                <table class="table accounting-table accounting-entries-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tipo</th>
                            <th>Cuenta</th>
                            <th>Debe</th>
                            <th>Haber</th>
                            <th>Balance</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody id="entriesTable"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .accounting-page {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

        .accounting-page,
        .accounting-page * {
            min-width: 0;
        }

    .accounting-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .accounting-title {
        margin: 0;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

        .accounting-title i {
            color: var(--primary);
        }

    .accounting-subtitle {
        margin: .35rem 0 0;
    }

    .accounting-kpi-grid {
        gap: 1rem;
    }

    .accounting-kpi-card h2 {
        margin: .35rem 0 0;
    }

    .accounting-main-grid {
        display: grid;
        grid-template-columns: minmax(340px, .85fr) minmax(0, 1.15fr);
        gap: 1rem;
        align-items: start;
    }

    .accounting-actions-card,
    .accounting-entries-card {
        align-self: start;
    }

    .accounting-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .accounting-section-title {
        margin: 0;
        font-size: 1.15rem;
    }

    .accounting-block {
        display: grid;
        gap: .25rem;
    }

    .accounting-form {
        display: grid;
        gap: .9rem;
    }

    .accounting-form-block {
        display: grid;
        gap: .35rem;
    }

        .accounting-form-block label {
            margin: 0;
            font-size: .82rem;
            font-weight: 700;
            color: var(--text);
        }

    .accounting-submit-btn {
        width: 100%;
    }

    .accounting-action-buttons {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

        .accounting-action-buttons .btn {
            flex: 1 1 220px;
        }

    .accounting-table-wrap {
        max-width: 100%;
        max-height: 560px;
        overflow: auto;
    }

    .accounting-table {
        width: 100%;
        min-width: 0 !important;
        margin: 0;
    }

    .accounting-entries-table {
        table-layout: fixed;
    }

        .accounting-entries-table th,
        .accounting-entries-table td {
            vertical-align: middle;
        }

            .accounting-entries-table th:nth-child(1),
            .accounting-entries-table td:nth-child(1) {
                width: 70px;
                white-space: nowrap;
            }

            .accounting-entries-table th:nth-child(2),
            .accounting-entries-table td:nth-child(2) {
                width: 170px;
                white-space: nowrap;
            }

            .accounting-entries-table th:nth-child(3),
            .accounting-entries-table td:nth-child(3) {
                width: 280px;
            }

            .accounting-entries-table th:nth-child(4),
            .accounting-entries-table td:nth-child(4),
            .accounting-entries-table th:nth-child(5),
            .accounting-entries-table td:nth-child(5) {
                width: 130px;
                white-space: nowrap;
            }

            .accounting-entries-table th:nth-child(6),
            .accounting-entries-table td:nth-child(6) {
                width: 120px;
                white-space: nowrap;
            }

            .accounting-entries-table th:nth-child(7),
            .accounting-entries-table td:nth-child(7) {
                width: 190px;
                white-space: nowrap;
            }

    .accounting-account-cell {
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.35;
    }

    .accounting-type-badge {
        display: inline-flex;
        align-items: center;
        padding: .28rem .65rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        line-height: 1.1;
        background: var(--bg-alt);
        border: 1px solid var(--border);
        color: var(--text);
    }

        .accounting-type-badge.type-sale {
            background: #ede9fe;
            border-color: #c4b5fd;
            color: #6d28d9;
        }

        .accounting-type-badge.type-supplier {
            background: #fce7f3;
            border-color: #f9a8d4;
            color: #be185d;
        }

    .accounting-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--bg-card);
    }

    .accounting-page .card:hover {
        transform: none;
        box-shadow: var(--shadow-sm);
        border-color: var(--border);
    }

        .accounting-page .card:hover::after {
            opacity: 0;
        }

    .accounting-page .table tbody tr:hover {
        transform: none;
        box-shadow: none;
        background: var(--bg-alt);
    }

    .accounting-page .btn:hover,
    .accounting-page .btn-primary:hover,
    .accounting-page .btn-outline:hover,
    .accounting-page .btn-secondary:hover,
    .accounting-page .btn-ghost:hover {
        transform: none;
    }

    .accounting-page .form-control:focus,
    .accounting-page input:focus,
    .accounting-page select:focus,
    .accounting-page textarea:focus {
        transform: none;
    }

    @@media (max-width: 1200px) {
        .accounting-main-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .accounting-entries-table {
            table-layout: auto;
            min-width: 1120px !important;
        }

        .accounting-action-buttons {
            flex-direction: column;
        }

            .accounting-action-buttons .btn {
                width: 100%;
            }
    }
</style>

@section Scripts {
    <script>
        (() => {
            let pageInitialized = false;
            let reconStatus = 'Pendiente';

            function render() {
                const entries = BakeSmartStore.accounting.entries();
                const expenses = BakeSmartStore.accounting.expenses();
                const payments = BakeSmartStore.accounting.supplierPayments();

                document.getElementById('accEntriesCount').textContent = entries.length;
                document.getElementById('accExpensesCount').textContent = expenses.length;
                document.getElementById('accPaymentsCount').textContent = payments.length;
                document.getElementById('accReconStatus').textContent = reconStatus;

                document.getElementById('entriesTable').innerHTML = entries.map(e => {
                    const typeClass =
                        e.type === 'VENTA' ? 'type-sale' :
                        e.type === 'PAGO_PROVEEDOR' ? 'type-supplier' :
                        '';

                    const typeLabel = e.type === 'PAGO_PROVEEDOR'
                        ? 'Pago proveedor'
                        : e.type;

                    return `
                        <tr>
                            <td>${e.id}</td>
                            <td>
                                <span class="accounting-type-badge ${typeClass}">
                                    ${typeLabel}
                                </span>
                            </td>
                            <td class="accounting-account-cell" title="${e.account}">
                                ${e.account}
                            </td>
                            <td>${app.utils.formatCurrency(e.debit)}</td>
                            <td>${app.utils.formatCurrency(e.credit)}</td>
                            <td>
                                <span class="badge ${e.balanced ? 'badge-success' : 'badge-warning'}">
                                    ${e.balanced ? 'Cuadrado' : 'Error'}
                                </span>
                            </td>
                            <td>${new Date(e.createdAt).toLocaleString('es-CR')}</td>
                        </tr>
                    `;
                }).join('') || `
                    <tr>
                        <td colspan="7" class="text-center text-muted">No hay asientos registrados.</td>
                    </tr>
                `;
            }

            document.getElementById('expenseForm').addEventListener('submit', (e) => {
                e.preventDefault();

                try {
                    BakeSmartStore.accounting.addExpense(Object.fromEntries(new FormData(e.target).entries()));
                    e.target.reset();
                    app.toast.success('Gasto registrado.');
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            document.getElementById('supplierPaymentForm').addEventListener('submit', (e) => {
                e.preventDefault();

                try {
                    BakeSmartStore.accounting.addSupplierPayment(Object.fromEntries(new FormData(e.target).entries()));
                    e.target.reset();
                    app.toast.success('Pago a proveedor registrado.');
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            document.getElementById('accReconcileBtn').addEventListener('click', () => {
                try {
                    const result = BakeSmartStore.accounting.reconcile();
                    reconStatus = result.status;
                    app.toast.info(`Conciliación completada: ${result.reviewed} revisadas, ${result.issues} diferencias.`);
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            document.getElementById('accCloseBtn').addEventListener('click', () => {
                try {
                    const result = BakeSmartStore.accounting.dailyClose();
                    app.toast.success(`Cierre ${result.closeId} creado con ${result.count} operaciones.`);
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            function initializePage() {
                if (pageInitialized) return;
                pageInitialized = true;
                render();
            }

            window.addEventListener('load', initializePage, { once: true });

            if (document.readyState === 'complete') {
                initializePage();
            }
        })();
    </script>
}